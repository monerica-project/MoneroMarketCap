@page
@model MoneroMarketCap.Pages.Admin.ActivityModel
@{
    ViewData["Title"] = "Admin — User Activity";

    string Pct(int count) => Model.TotalUsers > 0
        ? ((decimal)count / Model.TotalUsers * 100).ToString("N1") + "%"
        : "—";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>User Activity</h2>
    <a asp-page="/Admin/Index" class="btn btn-secondary btn-sm">← Back</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted" style="font-size:0.8rem">Total Users</div>
                <strong style="font-size:1.6rem">@Model.TotalUsers</strong>
            </div>
        </div>
    </div>
    @foreach (var b in Model.LoginBuckets)
    {
        <div class="col-6 col-lg-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted" style="font-size:0.8rem">Logged in &middot; @b.Label</div>
                    <strong style="font-size:1.6rem">@b.Count</strong>
                    <div class="text-muted" style="font-size:0.78rem">@Pct(b.Count) of users</div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">Logins by Time Range</h5>
                <table class="table market-table mb-0">
                    <thead>
                        <tr>
                            <th>Range</th>
                            <th class="text-end">Active Users</th>
                            <th class="text-end">% of Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.LoginBuckets)
                        {
                            <tr>
                                <td>@b.Label</td>
                                <td class="text-end mono">@b.Count</td>
                                <td class="text-end mono">@Pct(b.Count)</td>
                            </tr>
                        }
                        <tr>
                            <td>Never logged in</td>
                            <td class="text-end mono">@Model.NeverLoggedIn</td>
                            <td class="text-end mono">@Pct(Model.NeverLoggedIn)</td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>All users</th>
                            <th class="text-end mono">@Model.TotalUsers</th>
                            <th class="text-end mono">100.0%</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">New Signups by Time Range</h5>
                <table class="table market-table mb-0">
                    <thead>
                        <tr>
                            <th>Range</th>
                            <th class="text-end">New Users</th>
                            <th class="text-end">% of Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.SignupBuckets)
                        {
                            <tr>
                                <td>@b.Label</td>
                                <td class="text-end mono">@b.Count</td>
                                <td class="text-end mono">@Pct(b.Count)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Most Recent Logins</h5>
        @if (!Model.RecentLogins.Any())
        {
            <p class="text-muted mb-0">No users have logged in yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table market-table mb-0">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th class="text-end">Last Login (UTC)</th>
                            <th class="text-end">Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.RecentLogins)
                        {
                            <tr>
                                <td><strong>@u.Username</strong></td>
                                <td class="text-end mono">@u.LastLoginAt.ToString("g")</td>
                                <td class="text-end" style="font-size:0.85rem;color:var(--xmr-text-muted)">
                                    @u.CreatedAt.ToShortDateString()
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
