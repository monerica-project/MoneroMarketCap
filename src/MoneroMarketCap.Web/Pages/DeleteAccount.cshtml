@page
@model MoneroMarketCap.Pages.DeleteAccountModel
@{
    ViewData["Title"] = "Delete Account";
}

<h2 style="color:#dc3545">Delete Account</h2>

@if (Model.Error != null)
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="card mt-3" style="max-width:560px;background:var(--xmr-surface);border-color:#dc3545">
    <div class="card-header" style="background:#dc354520;color:#dc3545;font-weight:600">
        Permanent account deletion
    </div>
    <div class="card-body">
        <p><strong>This cannot be undone.</strong> Deleting your account will permanently remove:</p>
        <ul>
            <li>Your login and username</li>
            <li>All portfolios you've created</li>
            <li>All coin holdings and transactions within those portfolios</li>
            <li>All role assignments</li>
        </ul>

        <p class="mt-3">
            To confirm, enter your current password and type
            <code style="background:#222;padding:2px 6px;border-radius:3px">DELETE</code>
            in the box below.
        </p>

        <form method="post" asp-page-handler="">
            <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" />
            </div>
            <div class="mb-3">
                <label class="form-label">Type DELETE to confirm</label>
                <input asp-for="ConfirmText" type="text" class="form-control" autocomplete="off" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Permanently Delete My Account</button>
                <a asp-page="/Settings" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>