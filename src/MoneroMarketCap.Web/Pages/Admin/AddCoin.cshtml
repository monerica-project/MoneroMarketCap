@page
@model MoneroMarketCap.Pages.Admin.AddCoinModel
@{
    ViewData["Title"] = "Add Coin";
}

<h2>Add Coin</h2>
<a asp-page="/Admin/Index" class="btn btn-secondary btn-sm mb-4">← Back</a>

<div class="row g-4">

    {{!-- Quick add popular coins --}}
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Quick Add Popular Coins</h5>
                <p style="font-size:0.85rem;color:var(--xmr-text-muted)">
                    Select any combination and add them all at once.
                </p>
                <form method="post" asp-page-handler="BulkAdd">
                    <div style="max-height:380px;overflow-y:auto">
                        @foreach (var (id, label) in AddCoinModel.PopularCoins)
                        {
                            <div class="form-check py-1" style="border-bottom:1px solid var(--xmr-border)">
                                <input class="form-check-input" type="checkbox"
                                       name="BulkIds" value="@id" id="chk_@id" />
                                <label class="form-check-label" for="chk_@id"
                                       style="font-size:0.9rem">@label</label>
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Add Selected</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="document.querySelectorAll('.form-check-input').forEach(c=>c.checked=true)">
                            Select All
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="document.querySelectorAll('.form-check-input').forEach(c=>c.checked=false)">
                            Clear
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {{!-- Search CoinGecko --}}
    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Search CoinGecko</h5>
                <form method="post" asp-page-handler="Search" class="row g-2">
                    <div class="col">
                        <input asp-for="SearchQuery" class="form-control"
                               placeholder="e.g. pirate chain, haven, wownero" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.SearchResults.Any())
        {
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Results</h5>
                    <form method="post" asp-page-handler="Add">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Pick</th>
                                    <th></th>
                                    <th>Symbol</th>
                                    <th>Name</th>
                                    <th>CoinGecko ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.SearchResults)
                                {
                                    <tr>
                                        <td>
                                            <input type="radio" name="CoinGeckoId"
                                                   value="@r.Id" class="form-check-input" />
                                        </td>
                                        <td>
                                            @if (r.Thumb != null)
                                            {
                                                <img src="@r.Thumb" width="20" height="20"
                                                     style="border-radius:50%" />
                                            }
                                        </td>
                                        <td><strong>@r.Symbol</strong></td>
                                        <td>@r.Name</td>
                                        <td><code style="font-size:0.78rem">@r.Id</code></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <button type="submit" class="btn btn-primary btn-sm">Add Selected</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>