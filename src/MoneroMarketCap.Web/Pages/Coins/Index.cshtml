@page
@using MoneroMarketCap.Web.Helpers
@model MoneroMarketCap.Pages.Coins.IndexModel
@{
    ViewData["Title"] = "Coins";
    ViewData["MetaDescription"] = "Browse every cryptocurrency tracked by MoneroMarketCap, with prices and market caps valued in Monero (XMR). Find any coin, see what it's worth in XMR, and convert it to Monero.";
    var cur = Model.Currency;
    var rate = Model.RatePerUsd;
}

<h2>Coins</h2>

@if (!Model.AllCoins.Any())
{
    <p class="text-muted">No coins in the database yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Symbol</th>
                <th>Name</th>
                <th>Price (@cur.Code)</th>
                <th>Market Cap (@cur.Code)</th>
                <th>Circulating Supply</th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var coin in Model.AllCoins)
            {
                <tr>
                    <td><strong>@coin.Symbol</strong></td>
                    <td>@coin.Name</td>
                    <td>@MoneyFormatter.FormatPrice(coin.PriceUsd, cur, rate)</td>
                    <td>@MoneyFormatter.FormatLarge(coin.MarketCapUsd, cur, rate)</td>
                    <td>@coin.CirculatingSupply.ToString("N0")</td>
                    <td>@coin.UpdatedAt.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
