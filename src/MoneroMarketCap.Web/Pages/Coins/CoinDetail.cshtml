@page "/coins/{symbol}"
@model MoneroMarketCap.Pages.Coins.DetailModel
@using MoneroMarketCap.Services.Display
@using MoneroMarketCap.Web.Helpers
@{
    ViewData["Title"] = Model.Coin?.Symbol + " — " + Model.Coin?.Name;
    ViewBag.SponsorRotateIntervalSeconds = 30;
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var cur = Model.Currency;
    var rate = Model.RatePerUsd;
    var coin = Model.Coin!;
    var xmr = Model.Monero;
    var priceInXmr = xmr != null && xmr.PriceUsd > 0 ? coin.PriceUsd / xmr.PriceUsd : 0;

    var coinsPerXmr = coin.PriceUsd > 0 && xmr != null ? xmr.PriceUsd / coin.PriceUsd : 0;
    bool isXmr = coin.Symbol.ToUpper() == "XMR";

    // Prefer node-verified values when available; falls back to CoinGecko for non-XMR coins.
    var displayMarketCap = MoneroSupplyDisplay.EffectiveMarketCapUsd(coin);
    var displaySupply    = MoneroSupplyDisplay.EffectiveCirculatingSupply(coin);
    var xmrMarketCap     = xmr != null ? MoneroSupplyDisplay.EffectiveMarketCapUsd(xmr) : 0m;
    var hasNodeData      = MoneroSupplyDisplay.IsNodeSupplyFresh(coin);

    var mcapRatio = xmrMarketCap > 0 ? displayMarketCap / xmrMarketCap : 0;

    bool canConvert = isXmr
        ? (coin.PriceUsd > 0 && rate > 0)
        : (xmr != null && xmr.PriceUsd > 0 && coin.PriceUsd > 0);
}

<meta name="format-detection" content="telephone=no" />

<style>
    /* Chart view switcher — each view is one click, active is highlighted */
    .chart-mode-switch {
        flex-wrap: wrap;
    }
    .chart-mode-btn {
        font-size: .78rem;
        line-height: 1.4;
    }
    .chart-mode-btn.active {
        background: color-mix(in srgb, #FF6600 16%, transparent);
        border-color: #FF6600;
        color: #fff;
        box-shadow: 0 0 6px rgba(255, 102, 0, .35);
    }

    /* Moving-average overlay toolbar (price mode only) */
    .ma-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: .6rem;
    }
    .ma-chip {
        --ma-color: #888;
        border-color: rgba(255, 255, 255, .15);
        color: #aab;
        font-size: .78rem;
        line-height: 1.4;
        padding: .15rem .55rem;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }
    .ma-chip::before {
        content: "";
        width: 10px;
        height: 2px;
        border-radius: 2px;
        background: var(--ma-color);
        opacity: .4;
    }
    .ma-chip.active {
        border-color: var(--ma-color);
        color: #fff;
        background: color-mix(in srgb, var(--ma-color) 14%, transparent);
    }
    .ma-chip.active::before {
        opacity: 1;
        box-shadow: 0 0 6px var(--ma-color);
    }

</style>

<partial name="_SponsorBanner" />

<div class="mb-3">
    <a asp-page="/Index" class="btn btn-secondary btn-sm">← Back</a>
</div>


@if (isXmr && MoneroSupplyDisplay.IsNodeSupplyFresh(coin))
{
    <div class="mb-4 node-verified-notice">
        <span class="node-verified-check">✓</span>
        Circulating supply independently verified via our full node:
        <span class="mono node-verified-value">
            @coin.NodeSupply!.Value.ToString("N4", usd) XMR
        </span>
        at block @coin.NodeSupplyHeight!.Value.ToString("N0", usd)
        (@MoneroSupplyDisplay.FormatAgo(coin.NodeSupplyUpdatedAt))
    </div>
}

<!-- Header -->
<div class="d-flex align-items-center gap-3 mb-4">
    @if (!string.IsNullOrEmpty(coin.ImageUrl))
    {
        <img src="@coin.ImageUrl" width="48" height="48" class="coin-icon" />
    }
    <div>
        <h2 class="mb-0">@coin.Name <span class="coin-symbol-secondary">@coin.Symbol</span></h2>
        <span class="coin-rank-label">Rank #@coin.MarketCapRank</span>
    </div>
    <div class="ms-auto text-end">
        <div class="fs-3 fw-bold">
            @MoneyFormatter.FormatPrice(coin.PriceUsd, cur, rate)
        </div>
        <div class="@(Model.PriceChange24h >= 0 ? "text-success" : "text-danger")">
            @(Model.PriceChange24h >= 0 ? "▲" : "▼") @Math.Abs(Model.PriceChange24h).ToString("N2", usd)% 24h
        </div>
    </div>
</div>

@if (isXmr)
{
    <div class="mb-4">
        <a href="https://moneropricenow.com/"
           target="_blank"
           rel="noopener"
           class="btn btn-xmr-trade">
            Trade Monero (XMR)
        </a>
    </div>
}

@if (!isXmr && !string.IsNullOrEmpty(coin.TradeUrl))
{
    <div class="mb-4">
        <a href="@coin.TradeUrl"
           target="_blank"
           rel="sponsored noopener"
           class="btn btn-xmr-trade">
            Trade @coin.Symbol for Monero
        </a>
    </div>
}

<!-- Converter -->
@if (canConvert)
{
    <div class="card mb-4 converter-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>💱 Convert XMR ⇄ @(isXmr ? cur.Code : coin.Symbol)</span>
            <span class="conv-rate-note mono">
                @if (isXmr)
                {
                    <text>1 XMR = @MoneyFormatter.FormatPrice(coin.PriceUsd, cur, rate)</text>
                }
                else
                {
                    <text>1 XMR = @coinsPerXmr.ToString(coinsPerXmr >= 1 ? "N4" : "N8", usd) @coin.Symbol</text>
                }
            </span>
        </div>
        <div class="card-body">
            <div class="converter">
                <div class="conv-field">
                    <label class="conv-label" for="conv-xmr">Monero</label>
                    <div class="conv-input-wrap">
                        <input id="conv-xmr" class="conv-input mono" type="number" inputmode="decimal"
                               min="0" step="any" value="1" autocomplete="off" />
                        <span class="conv-unit">XMR</span>
                    </div>
                </div>
                <div class="conv-swap" aria-hidden="true">⇅</div>
                <div class="conv-field">
                    <label class="conv-label" for="conv-other">@(isXmr ? cur.Code : coin.Name)</label>
                    <div class="conv-input-wrap">
                        <input id="conv-other" class="conv-input mono" type="number" inputmode="decimal"
                               min="0" step="any" autocomplete="off" />
                        <span class="conv-unit">@(isXmr ? cur.Code : coin.Symbol)</span>
                    </div>
                </div>
            </div>
            <div class="conv-hint">
                Type in either field to convert both ways. Rates reflect the current spot price and refresh with the page.
            </div>
        </div>
    </div>
}

<!-- Price changes + key stats -->
<div class="xmr-stat-bar mb-4">
    <div class="xmr-stat">
        <span class="stat-label">1h</span>
        <span class="stat-value @(Model.PriceChange1h >= 0 ? "text-success" : "text-danger")">
            @(Model.PriceChange1h >= 0 ? "▲" : "▼") @Math.Abs(Model.PriceChange1h).ToString("N2", usd)%
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">7d</span>
        <span class="stat-value @(Model.PriceChange7d >= 0 ? "text-success" : "text-danger")">
            @(Model.PriceChange7d >= 0 ? "▲" : "▼") @Math.Abs(Model.PriceChange7d).ToString("N2", usd)%
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">30d</span>
        <span class="stat-value @(Model.PriceChange30d >= 0 ? "text-success" : "text-danger")">
            @(Model.PriceChange30d >= 0 ? "▲" : "▼") @Math.Abs(Model.PriceChange30d).ToString("N2", usd)%
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">1yr</span>
        <span class="stat-value @(Model.PriceChange1y >= 0 ? "text-success" : "text-danger")">
            @(Model.PriceChange1y >= 0 ? "▲" : "▼") @Math.Abs(Model.PriceChange1y).ToString("N2", usd)%
        </span>
    </div>
<div class="xmr-stat">
    <span class="stat-label">
        Market Cap
    </span>
    <span class="stat-value">
        @MoneyFormatter.FormatLarge(displayMarketCap, cur, rate)
    </span>
</div>
    <div class="xmr-stat">
        <span class="stat-label">24h Volume</span>
        <span class="stat-value">
            @MoneyFormatter.FormatLarge(coin.TotalVolume, cur, rate)
        </span>
    </div>
    @if (isXmr)
{
    <div class="xmr-stat">
        <span class="stat-label">
            Circulating Supply

        </span>
        <span class="stat-value">
            @((displaySupply / 1_000_000m).ToString("N3", usd))M XMR
        </span>
    </div>
}
</div>

<!-- Last updated -->
<div class="table-meta mb-3">
    <span>
        <span class="text-muted">Data updated:</span>
        <span class="cursor-default"
              title="@coin.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC">
            @coin.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC
        </span>
    </span>
</div>

<!-- Price chart -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span id="chart-title">Price (@cur.Code) — Last 365 Days</span>
        <div class="d-flex align-items-center gap-2">
            <div id="mode-switch" class="btn-group btn-group-sm chart-mode-switch d-none" role="group"></div>
            <span id="chart-status" class="chart-status">Loading...</span>
        </div>
    </div>
    <div class="card-body chart-canvas-wrap">
        <div id="ma-toolbar" class="ma-toolbar d-none"></div>
        <canvas id="price-chart"></canvas>
    </div>
</div>

<!-- vs XMR comparison -->
@if (!isXmr && xmr != null)
{
    <div class="card mb-4">
        <div class="card-header">@coin.Symbol vs Monero (XMR)</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 stats-table">
                <tbody>
                    <tr>
                        <td class="text-muted w-50">Price in XMR</td>
                        <td class="mono">
                            @if (priceInXmr >= 1)
                            {
                                <text>@priceInXmr.ToString("N4", usd) XMR</text>
                            }
                            else
                            {
                                <text>@priceInXmr.ToString("N8", usd) XMR</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">1 XMR buys</td>
                        <td class="mono">
                            @if (coinsPerXmr >= 1)
                            {
                                <text>@coinsPerXmr.ToString("N2", usd) @coin.Symbol</text>
                            }
                            else
                            {
                                <text>@coinsPerXmr.ToString("N8", usd) @coin.Symbol</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Market Cap vs XMR</td>
                        <td class="mono">
                            @if (mcapRatio >= 1)
                            {
                                <span class="ratio-larger">@mcapRatio.ToString("N1", usd)× larger</span>
                            }
                            else
                            {
                                <span class="ratio-smaller">@((mcapRatio * 100).ToString("N1", usd))% of XMR</span>
                            }
                        </td>
                    </tr>
                    @{
                        void RenderVsXmrRow(string label, decimal? change, string symbol)
                        {
                            <tr>
                                <td class="text-muted">
                                    vs XMR (@label)
                                    <span class="stats-sublabel">
                                        Holding @symbol vs holding XMR
                                    </span>
                                </td>
                                <td class="mono">
                                    @if (change.HasValue)
                                    {
                                        var v = change.Value;
                                        <span class="@(v >= 0 ? "text-success" : "text-danger")">
                                            @(v >= 0 ? "▲" : "▼") @Math.Abs(v).ToString("N1", usd)%
                                        </span>
                                        <span class="stats-note">
                                            @(v >= 0 ? $"{symbol} outperformed XMR" : $"XMR outperformed {symbol}")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Insufficient history</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    @{
                        RenderVsXmrRow("24h", Model.VsXmrChange24h, coin.Symbol);
                    }
                    @{
                        RenderVsXmrRow("7d", Model.VsXmrChange7d, coin.Symbol);
                    }
                    @{
                        RenderVsXmrRow("30d", Model.VsXmrChange30d, coin.Symbol);
                    }
                    @{
                        RenderVsXmrRow("1yr", Model.VsXmrChange1yr, coin.Symbol);
                    }
                    <tr>
                        <td class="text-muted">Circulating Supply</td>
                        <td class="mono">@coin.CirculatingSupply.ToString("N0", usd) @coin.Symbol</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Max Supply</td>
                        <td class="mono">
                            @if (coin.MaxSupply.HasValue)
                            {
                                <text>@coin.MaxSupply.Value.ToString("N0", usd) @coin.Symbol</text>
                            }
                            else
                            {
                                <span class="text-muted">∞ (no cap)</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">24h High</td>
                        <td class="mono">
                            @MoneyFormatter.FormatPrice(coin.High24h, cur, rate)
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">24h Low</td>
                        <td class="mono">
                            @MoneyFormatter.FormatPrice(coin.Low24h, cur, rate)
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">All-Time High</td>
                        <td class="mono">
                            @MoneyFormatter.FormatPrice(coin.Ath, cur, rate)
                            <span class="@(coin.AthChangePercentage >= 0 ? "text-success" : "text-danger") ath-change-pct">
                                (@coin.AthChangePercentage.ToString("N1", usd)%)
                            </span>
                        </td>
                    </tr>
                    @if (coin.AthDate != default)
                    {
                        <tr>
                            <td class="text-muted">ATH Date</td>
                            <td class="mono text-muted">@coin.AthDate?.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted">Market Cap Rank</td>
                        <td class="mono">#@coin.MarketCapRank</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}

@if (isXmr)
{
    <div class="card mb-4">
        <div class="card-header">Monero (XMR) Stats</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 stats-table">
                <tbody>
                    @{
                        var hasNode = MoneroSupplyDisplay.IsNodeSupplyFresh(coin);
                        var nodeSupply = hasNode ? coin.NodeSupply!.Value : 0m;
                        var nodeMarketCap = hasNode ? nodeSupply * coin.PriceUsd : 0m;
                    }

                    <tr>
                        <td class="text-muted w-50">
                            Market Cap

                        </td>
                        <td class="mono">
                            @if (hasNode)
                            {
                                <div>@MoneyFormatter.FormatLarge(nodeMarketCap, cur, rate)</div>
                                <div class="value-sub">
                                    CoinGecko: @MoneyFormatter.FormatLarge(coin.MarketCapUsd, cur, rate)
                                </div>
                            }
                            else
                            {
                                @MoneyFormatter.FormatLarge(coin.MarketCapUsd, cur, rate)
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">
                            Circulating Supply

                        </td>
                        <td class="mono">
                            @if (hasNode)
                            {
                                <div>@nodeSupply.ToString("N0", usd) XMR</div>
                                <div class="value-sub">
                                    at block @coin.NodeSupplyHeight!.Value.ToString("N0", usd)
                                    · CoinGecko: @coin.CirculatingSupply.ToString("N0", usd) XMR
                                </div>
                            }
                            else
                            {
                                <text>@coin.CirculatingSupply.ToString("N0", usd) XMR</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Max Supply</td>
                        <td class="mono">
                            @if (coin.MaxSupply.HasValue)
                            {
                                <text>@coin.MaxSupply.Value.ToString("N0", usd) XMR</text>
                            }
                            else
                            {
                                <span class="text-muted">∞ (no cap)</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">24h High</td>
                        <td class="mono">@MoneyFormatter.FormatPrice(coin.High24h, cur, rate)</td>
                    </tr>
                    <tr>
                        <td class="text-muted">24h Low</td>
                        <td class="mono">@MoneyFormatter.FormatPrice(coin.Low24h, cur, rate)</td>
                    </tr>
                    <tr>
                        <td class="text-muted">All-Time High</td>
                        <td class="mono">
                            @MoneyFormatter.FormatPrice(coin.Ath, cur, rate)
                            <span class="@(coin.AthChangePercentage >= 0 ? "text-success" : "text-danger") ath-change-pct">
                                (@coin.AthChangePercentage.ToString("N1", usd)%)
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Market Cap Rank</td>
                        <td class="mono">#@coin.MarketCapRank</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">How we calculate Monero's supply</div>
        <div class="card-body calc-body">
            <p>
                Most market cap sites pull Monero's circulating supply from an aggregator
                (CoinGecko, CoinMarketCap), which refreshes infrequently and can lag the real
                chain by hundreds of thousands of XMR. We compute the supply directly from the
                current block height using Monero's published emission formula.
            </p>

            <h6>The formula</h6>
            <pre class="calc-formula"><code>supply ≈ 18,132,009 + (current_height − 2,641,623) × 0.6</code></pre>
            <ul>
                <li><strong>18,132,009 XMR</strong> — approximate total emitted before tail emission began</li>
                <li><strong>Block 2,641,623</strong> — the block at which tail emission activated (≈ May 2022)</li>
                <li><strong>0.6 XMR per block</strong> — the fixed tail emission reward that continues forever</li>
            </ul>

            @if (MoneroSupplyDisplay.IsNodeSupplyFresh(coin) && coin.NodeSupplyHeight.HasValue)
            {
                <p>
                    <strong>At block @coin.NodeSupplyHeight.Value.ToString("N0", usd):</strong>
                    18,132,009 + (@coin.NodeSupplyHeight.Value.ToString("N0", usd) − 2,641,623) × 0.6 =
                    <span class="mono">@coin.NodeSupply!.Value.ToString("N0", usd) XMR</span>
                </p>
            }

            <h6>How we verify the block height</h6>
            <p>
                Our backend runs a full Monero node (via our self-hosted
                BTCPay Server)
                that is in constant sync with the Monero network. The block height reported above
                is read directly from our node every few minutes — not from any third-party
                aggregator or block explorer.
            </p>

            <h6>Caveats — why this is an estimate, not an exact figure</h6>
            <p class="mb-2">
                The formula above gives the supply from base block rewards only. It <em>does not</em>
                include transaction fees, which are also added to each coinbase transaction.
                Over 1M+ blocks since tail emission began, accumulated fees add roughly
                10,000–20,000 XMR to the true total.
            </p>
            <p class="mb-0">
                For the exact total (block rewards + all tx fees, summed from genesis),
                see <a href="https://moneroinflation.com" target="_blank" rel="noopener">moneroinflation.com</a>,
                which runs the full Monero consensus code to verify every block's emission.
                Our number is typically within ~0.1% of theirs, and always closer to the truth
                than CoinGecko's (which commonly lags by hundreds of thousands of XMR).
            </p>

            <h6>Verify it yourself</h6>
            <ul>
                <li>
                    <a href="https://www.getmonero.org/resources/moneropedia/tail-emission.html" target="_blank" rel="noopener">
                        Monero's official tail emission documentation
                    </a>
                </li>
                <li>
                    <a href="https://github.com/monero-project/monero/blob/master/src/cryptonote_config.h" target="_blank" rel="noopener">
                        Emission constants in the Monero source code
                    </a>
                </li>
                <li>
                    <a href="https://moneroinflation.com" target="_blank" rel="noopener">
                        moneroinflation.com — independent full-node supply verifier
                    </a>
                </li>
                <li>
                    <a href="https://github.com/DangerousFreedom1984/monero_inflation_checker" target="_blank" rel="noopener">
                        monero_inflation_checker — the tool behind moneroinflation.com
                    </a>
                </li>
            </ul>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/chart.umd.min.js"></script>
    <script>
        const coinGeckoId = '@coin.CoinGeckoId';
        const coinSymbol = '@coin.Symbol';
        const isXmr = coinSymbol === 'XMR';

        // ─── Currency context (server-rendered, drives chart formatting) ──────────
        // Server returns chart data ALREADY in the target currency (joined against
        // FiatRateHistory at render time). For the "vs USD" overlay we fetch the
        // same coin a second time with currency=USD as a baseline.
        const CURRENCY = {
            code: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cur.Code)),
            symbol: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cur.Symbol)),
            before: @(cur.SymbolBefore ? "true" : "false"),
            decimals: @cur.Decimals
        };
        const isUsd = CURRENCY.code === 'USD';

        let chartInstance = null;
        let rawCoin    = null;   // [[ts, priceInSelectedCurrency], ...]  (from server)
        let rawXmr     = null;   // XMR in selected currency
        let rawCoinUsd = null;   // this coin in USD (baseline for "vs USD" mode)

        // Available modes depend on context:
        //   price → coin in selected currency (absolute)
        //   usd   → coin's % return in selected currency vs in USD  (currency effect)
        //   vs    → coin vs XMR, both normalized from selected-currency prices
        // Each mode gets its own one-click button in the switcher.
        const MODES = ['price'];
        if (!isUsd) MODES.push('usd');     // nothing to compare if we're already USD
        if (!isXmr) MODES.push('vs');      // XMR can't be compared to itself
        // Monero-focused site: open on the vs-XMR view when it's available
        // (i.e. every coin except XMR itself, which falls back to price).
        let mode = MODES.includes('vs') ? 'vs' : MODES[0];

        // ─── Moving-average overlays (price mode only) ────────────────────────────
        // Data is 365 daily points, so period == days. Add/remove a line here and
        // it shows up as a toggle chip automatically. Colors are chosen to stay
        // distinct from the blue price line (#4a9eff) and orange XMR line (#FF6600).
        const INDICATORS = [
            { id: 'sma50',  type: 'sma', period: 50,  label: 'SMA 50',  color: '#f5d76e' },
            { id: 'sma200', type: 'sma', period: 200, label: 'SMA 200', color: '#b18aff' },
            { id: 'ema21',  type: 'ema', period: 21,  label: 'EMA 21',  color: '#2ecc71' }
        ];
        const activeIndicators = new Set();   // ids currently displayed (persists across mode switches)

        // Simple moving average. Leading (period-1) entries are null so Chart.js
        // draws a clean gap rather than a misleading partial line.
        function sma(values, period) {
            const out = new Array(values.length).fill(null);
            if (values.length < period) return out;
            let sum = 0;
            for (let i = 0; i < values.length; i++) {
                sum += values[i];
                if (i >= period) sum -= values[i - period];
                if (i >= period - 1) out[i] = sum / period;
            }
            return out;
        }

        // Exponential moving average, seeded with the SMA of the first `period`
        // points (the standard convention). Same null-padding behavior as sma().
        function ema(values, period) {
            const out = new Array(values.length).fill(null);
            if (values.length < period) return out;
            const k = 2 / (period + 1);
            let prev;
            for (let i = 0; i < values.length; i++) {
                if (i < period - 1) continue;
                if (i === period - 1) {
                    let seed = 0;
                    for (let j = 0; j < period; j++) seed += values[j];
                    prev = seed / period;
                    out[i] = prev;
                } else {
                    prev = values[i] * k + prev * (1 - k);
                    out[i] = prev;
                }
            }
            return out;
        }

        // ── Formatting helpers ────────────────────────────────────────────────────
        function wrapMoney(numberPart) {
            return CURRENCY.before
                ? CURRENCY.symbol + numberPart
                : numberPart + ' ' + CURRENCY.symbol;
        }

        function formatPrice(v) {
            let n;
            if (CURRENCY.decimals === 0) {
                n = v >= 1
                    ? v.toLocaleString('en-US', { maximumFractionDigits: 0 })
                    : v.toFixed(2);
            } else if (v >= 1000) {
                n = v.toLocaleString('en-US', {
                    minimumFractionDigits: CURRENCY.decimals,
                    maximumFractionDigits: CURRENCY.decimals
                });
            } else if (v >= 1) {
                n = v.toFixed(CURRENCY.decimals);
            } else if (v >= 0.01) {
                n = v.toFixed(4);
            } else {
                n = v.toFixed(8);
            }
            return wrapMoney(n);
        }

        function formatAxisPrice(v) {
            if (v >= 1000) return wrapMoney((v / 1000).toFixed(1) + 'k');
            if (v >= 1)    return wrapMoney(v.toFixed(CURRENCY.decimals || 2));
            if (v >= 0.01) return wrapMoney(v.toFixed(4));
            return wrapMoney(v.toFixed(6));
        }

        // ── Pure series helpers ───────────────────────────────────────────────────
        function normalize(series) {
            if (!series.length) return [];
            const base = series[0][1];
            if (!base) return series.map(p => [p[0], 0]);
            return series.map(p => [p[0], ((p[1] / base) - 1) * 100]);
        }

        function alignSeries(a, b) {
            const bMap = new Map(b.map(p => [new Date(p[0]).toDateString(), p[1]]));
            return a.map(p => {
                const key = new Date(p[0]).toDateString();
                return [p[0], bMap.get(key) ?? null];
            });
        }

        // ── Build the chart for the current mode ──────────────────────────────────
        function buildChart() {
            const ctx = document.getElementById('price-chart').getContext('2d');
            if (chartInstance) { chartInstance.destroy(); chartInstance = null; }

            const labels = rawCoin.map(p => {
                const d = new Date(p[0]);
                return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            });

            let datasets;
            let isPctMode = true;

            if (mode === 'price') {
                // Absolute price in the selected currency. Plot directly.
                // XMR page = orange, all other coins = blue.
                isPctMode = false;
                datasets = [{
                    label: coinSymbol + ' Price (' + CURRENCY.code + ')',
                    data: rawCoin.map(p => p[1]),
                    borderColor: isXmr ? '#FF6600' : '#4a9eff',
                    backgroundColor: isXmr ? 'rgba(255,102,0,0.08)' : 'rgba(74,158,255,0.08)',
                    borderWidth: 1.5,
                    pointRadius: 0,
                    pointHoverRadius: 4,
                    tension: 0.2,
                    fill: true,
                    yAxisID: 'y'
                }];

                // Overlay any active moving averages, computed on the same
                // selected-currency price array so they sit directly on the line.
                const prices = rawCoin.map(p => p[1]);
                for (const ind of INDICATORS) {
                    if (!activeIndicators.has(ind.id)) continue;
                    const series = ind.type === 'ema'
                        ? ema(prices, ind.period)
                        : sma(prices, ind.period);
                    datasets.push({
                        label: ind.label,
                        data: series,
                        borderColor: ind.color,
                        backgroundColor: 'transparent',
                        borderWidth: 1.25,
                        pointRadius: 0,
                        pointHoverRadius: 3,
                        tension: 0.2,
                        fill: false,
                        spanGaps: false,
                        yAxisID: 'y'
                    });
                }
            } else if (mode === 'usd') {
                // Currency effect: this coin's % return in the selected currency
                // vs its % return in USD. The gap between the lines IS the FX
                // contribution — a weak fiat lifts its line above USD, a strong
                // fiat pushes it below. Both derived from server-converted prices.
                const normSel = normalize(rawCoin);
                const usdAligned = alignSeries(rawCoin, rawCoinUsd || []);
                const normUsd = normalize(usdAligned);

                datasets = [
                    {
                        label: coinSymbol + ' in ' + CURRENCY.code + ' (% change)',
                        data: normSel.map(p => p[1]),
                        borderColor: '#4a9eff',
                        backgroundColor: 'rgba(74,158,255,0.06)',
                        borderWidth: 1.5,
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        tension: 0.2,
                        fill: false,
                        yAxisID: 'y'
                    },
                    {
                        label: coinSymbol + ' in USD (% change)',
                        data: normUsd.map(p => p[1]),
                        borderColor: '#9aa4b2',
                        backgroundColor: 'rgba(154,164,178,0.04)',
                        borderWidth: 1.25,
                        borderDash: [5, 4],
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        tension: 0.2,
                        fill: false,
                        yAxisID: 'y'
                    }
                ];
            } else {
                // vs XMR: coin vs Monero, both normalized from SELECTED-currency
                // prices, so the fiat context carries through into both lines.
                const normCoin = normalize(rawCoin);
                const xmrAligned = alignSeries(rawCoin, rawXmr || []);

                datasets = [
                    {
                        label: coinSymbol + ' in ' + CURRENCY.code + ' (% change)',
                        data: normCoin.map(p => p[1]),
                        borderColor: '#4a9eff',
                        backgroundColor: 'rgba(74,158,255,0.06)',
                        borderWidth: 1.5,
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        tension: 0.2,
                        fill: false,
                        yAxisID: 'y'
                    },
                    {
                        label: 'XMR in ' + CURRENCY.code + ' (% change)',
                        data: normalize(xmrAligned).map(p => p[1]),
                        borderColor: '#FF6600',
                        backgroundColor: 'rgba(255,102,0,0.06)',
                        borderWidth: 1.5,
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        tension: 0.2,
                        fill: false,
                        yAxisID: 'y'
                    }
                ];
            }

            // Show the legend whenever there's more than one line to disambiguate:
            // always in the % modes, and in price mode once an MA overlay is on.
            const showLegend = isPctMode || (mode === 'price' && activeIndicators.size > 0);

            chartInstance = new Chart(ctx, {
                type: 'line',
                data: { labels, datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: showLegend, labels: { color: '#aaa', boxWidth: 12 } },
                        tooltip: {
                            callbacks: {
                                label: ctx => {
                                    const v = ctx.parsed.y;
                                    if (v === null) return null;
                                    if (isPctMode) {
                                        return ctx.dataset.label + ': ' + (v >= 0 ? '+' : '') + v.toFixed(2) + '%';
                                    }
                                    // Price mode: prefix with the line label when MA
                                    // overlays are present so prices aren't ambiguous.
                                    const prefix = ctx.chart.data.datasets.length > 1
                                        ? ctx.dataset.label + ': '
                                        : '';
                                    return prefix + formatPrice(v);
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#888', maxTicksLimit: 12, maxRotation: 0 },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        y: {
                            ticks: {
                                color: '#888',
                                callback: v => isPctMode
                                    ? (v >= 0 ? '+' : '') + v.toFixed(0) + '%'
                                    : formatAxisPrice(v)
                            },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        }
                    }
                }
            });

            updateChartChrome();
        }

        // ── Title reflects the active mode ────────────────────────────────────────
        function titleFor(m) {
            if (m === 'price') return 'Price (' + CURRENCY.code + ') — Last 365 Days';
            if (m === 'usd')   return coinSymbol + ': ' + CURRENCY.code + ' vs USD — Last 365 Days';
            return coinSymbol + ' vs XMR (' + CURRENCY.code + ') — Last 365 Days';
        }

        // Label shown on each one-click mode button.
        function modeLabel(m) {
            if (m === 'price') return 'Price (' + CURRENCY.code + ')';
            if (m === 'usd')   return 'vs USD';
            return 'vs XMR';
        }

        // Build one button per available mode. Each switches directly to that
        // view in a single click — no cycling. Hidden entirely when only one
        // mode applies (e.g. the XMR page viewed in USD).
        function initModeSwitch() {
            const sw = document.getElementById('mode-switch');
            if (!sw) return;
            sw.innerHTML = '';
            if (MODES.length <= 1) { sw.classList.add('d-none'); return; }
            for (const m of MODES) {
                const b = document.createElement('button');
                b.type = 'button';
                b.className = 'btn btn-outline-secondary btn-sm chart-mode-btn';
                b.textContent = modeLabel(m);
                b.dataset.mode = m;
                b.addEventListener('click', () => setMode(m));
                sw.appendChild(b);
            }
            sw.classList.remove('d-none');
        }

        function setMode(m) {
            if (!MODES.includes(m)) return;
            mode = m;
            buildChart();
        }

        function updateChartChrome() {
            document.getElementById('chart-title').textContent = titleFor(mode);

            // Highlight the active mode button.
            const sw = document.getElementById('mode-switch');
            if (sw) {
                for (const b of sw.querySelectorAll('.chart-mode-btn')) {
                    b.classList.toggle('active', b.dataset.mode === mode);
                }
            }

            // MA chips are only meaningful on the absolute price chart.
            const maBar = document.getElementById('ma-toolbar');
            if (maBar) maBar.classList.toggle('d-none', mode !== 'price');
        }

        // Build the MA toggle chips once from the INDICATORS config. Stays hidden
        // until updateChartChrome() reveals it in price mode.
        function initIndicatorToolbar() {
            const bar = document.getElementById('ma-toolbar');
            if (!bar) return;
            bar.innerHTML = '';
            for (const ind of INDICATORS) {
                const b = document.createElement('button');
                b.type = 'button';
                b.className = 'btn btn-sm ma-chip';
                b.textContent = ind.label;
                b.style.setProperty('--ma-color', ind.color);
                b.dataset.id = ind.id;
                if (activeIndicators.has(ind.id)) b.classList.add('active');
                b.addEventListener('click', () => {
                    if (activeIndicators.has(ind.id)) {
                        activeIndicators.delete(ind.id);
                        b.classList.remove('active');
                    } else {
                        activeIndicators.add(ind.id);
                        b.classList.add('active');
                    }
                    buildChart();
                });
                bar.appendChild(b);
            }
        }

        // ── Fetch chart data ─────────────────────────────────────────────────────
        // Fetch the coin in the selected currency always. Additionally fetch:
        //   - XMR in the selected currency (for vs XMR), unless this IS XMR
        //   - the coin in USD (for vs USD), unless we're already in USD
        async function loadChart() {
            document.getElementById('chart-status').textContent = 'Loading...';
            try {
                const qs    = '?currency=' + encodeURIComponent(CURRENCY.code);
                const usdQs = '?currency=USD';

                const [coinRes, xmrRes, coinUsdRes] = await Promise.all([
                    fetch('/api/coin/' + coinGeckoId + '/chart' + qs),
                    isXmr ? Promise.resolve(null) : fetch('/api/coin/monero/chart' + qs),
                    isUsd ? Promise.resolve(null) : fetch('/api/coin/' + coinGeckoId + '/chart' + usdQs)
                ]);

                if (!coinRes.ok) throw new Error('fetch failed');
                const coinJson = await coinRes.json();
                rawCoin = Array.isArray(coinJson) ? coinJson : (coinJson.prices ?? []);

                if (xmrRes) {
                    const xmrJson = await xmrRes.json();
                    rawXmr = Array.isArray(xmrJson) ? xmrJson : (xmrJson.prices ?? []);
                }

                if (coinUsdRes) {
                    const usdJson = await coinUsdRes.json();
                    rawCoinUsd = Array.isArray(usdJson) ? usdJson : (usdJson.prices ?? []);
                }

                if (!rawCoin.length) {
                    document.getElementById('chart-status').textContent = 'No data available';
                    return;
                }

                document.getElementById('chart-status').textContent = rawCoin.length + ' days';
                initModeSwitch();
                initIndicatorToolbar();
                buildChart();
            } catch (e) {
                document.getElementById('chart-status').textContent = 'Chart unavailable';
            }
        }

        loadChart();

        // ─── XMR ⇄ converter ──────────────────────────────────────────────────────
        // perXmr = how many units of the "other" side equal 1 XMR.
        //   XMR page  → other side is the selected fiat currency (coin.PriceUsd × rate)
        //   alt coins → other side is this coin                  (coinsPerXmr)
        // Server-rendered at the current spot price; refreshes with the page.
        (function () {
            const xmrInput   = document.getElementById('conv-xmr');
            const otherInput = document.getElementById('conv-other');
            if (!xmrInput || !otherInput) return;

            const perXmr    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(isXmr ? (coin.PriceUsd * rate) : coinsPerXmr));
            const otherFiat = isXmr;

            const strip = s => s.indexOf('.') === -1 ? s : s.replace(/0+$/, '').replace(/\.$/, '');

            function fmtCrypto(v) {
                if (!isFinite(v) || v < 0) return '';
                if (v === 0) return '0';
                const a = Math.abs(v);
                const dec = a >= 1000 ? 4 : a >= 1 ? 6 : a >= 0.0001 ? 8 : 10;
                return strip(v.toFixed(dec));
            }
            function fmtFiat(v) {
                if (!isFinite(v) || v < 0) return '';
                return v.toFixed(Math.max(CURRENCY.decimals, 2));
            }
            const fmtOther = otherFiat ? fmtFiat : fmtCrypto;

            function fromXmr() {
                const x = parseFloat(xmrInput.value);
                otherInput.value = isNaN(x) ? '' : fmtOther(x * perXmr);
            }
            function fromOther() {
                const o = parseFloat(otherInput.value);
                xmrInput.value = (isNaN(o) || perXmr <= 0) ? '' : fmtCrypto(o / perXmr);
            }

            xmrInput.addEventListener('input', fromXmr);
            otherInput.addEventListener('input', fromOther);

            xmrInput.value = '1';   // seed with 1 XMR
            fromXmr();
        })();
    </script>
}