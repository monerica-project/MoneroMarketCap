@page "/coins/{symbol}"
@model MoneroMarketCap.Pages.Coins.DetailModel
@using MoneroMarketCap.Services.Display
@{
    ViewData["Title"] = Model.Coin?.Symbol + " — " + Model.Coin?.Name;
    ViewBag.SponsorRotateIntervalSeconds = 30;
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var coin = Model.Coin!;
    var xmr = Model.Monero;
    var priceInXmr = xmr != null && xmr.PriceUsd > 0 ? coin.PriceUsd / xmr.PriceUsd : 0;
    var mcapRatio = xmr != null && xmr.MarketCapUsd > 0 ? coin.MarketCapUsd / xmr.MarketCapUsd : 0;
    var coinsPerXmr = coin.PriceUsd > 0 && xmr != null ? xmr.PriceUsd / coin.PriceUsd : 0;
    bool isXmr = coin.Symbol.ToUpper() == "XMR";
}

<meta name="format-detection" content="telephone=no" />

<partial name="_SponsorBanner" />

<div class="mb-3">
    <a asp-page="/Index" class="btn btn-secondary btn-sm">← Back</a>
</div>


@if (isXmr && MoneroSupplyDisplay.IsNodeSupplyFresh(coin))
{
    <div class="mb-4" style="font-size:0.82rem;color:var(--xmr-text-muted)">
        <span style="color:#1a7f3c">✓</span>
        Circulating supply independently verified via our full node:
        <span class="mono" style="color:var(--xmr-text)">
            @coin.NodeSupply!.Value.ToString("N4", usd) XMR
        </span>
        at block @coin.NodeSupplyHeight!.Value.ToString("N0", usd)
        (@MoneroSupplyDisplay.FormatAgo(coin.NodeSupplyUpdatedAt))
    </div>
}

<!-- Header -->
<div class="d-flex align-items-center gap-3 mb-4">
    @if (!string.IsNullOrEmpty(coin.ImageUrl))
    {
        <img src="@coin.ImageUrl" width="48" height="48" style="border-radius:50%" />
    }
    <div>
        <h2 class="mb-0">@coin.Name <span style="color:var(--xmr-text-muted);font-size:1rem">@coin.Symbol</span></h2>
        <span style="color:var(--xmr-text-muted);font-size:0.82rem">Rank #@coin.MarketCapRank</span>
    </div>
    <div class="ms-auto text-end">
        <div class="fs-3 fw-bold">
            @if (coin.PriceUsd >= 1)
            {
                <text>$@coin.PriceUsd.ToString("N2", usd)</text>
            }
            else if (coin.PriceUsd >= 0.01m)
            {

                <text>$@coin.PriceUsd.ToString("N4", usd)</text>
            }
            else
            {

                <text>$@coin.PriceUsd.ToString("N8", usd)</text>
            }
        </div>
        <div class="@(coin.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
            @(coin.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent24h).ToString("N2", usd)% 24h
        </div>
    </div>
</div>

@if (isXmr)
{
    <div class="mb-4">
        <a href="https://moneropricenow.com/"
               target="_blank"
               rel="noopener"
               class="btn btn-warning fw-bold"
               style="background:var(--xmr-orange);border-color:var(--xmr-orange);color:#fff">
            Buy Monero (XMR)
        </a>
    </div>
}

<!-- Price changes + key stats -->
<div class="xmr-stat-bar mb-4">
    <div class="xmr-stat">
        <span class="stat-label">1h</span>
        <span class="stat-value @(coin.PriceChangePercent1h >= 0 ? "text-success" : "text-danger")">
            @(coin.PriceChangePercent1h >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent1h).ToString("N2", usd)%
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">7d</span>
        <span class="stat-value @(coin.PriceChangePercent7d >= 0 ? "text-success" : "text-danger")">
            @(coin.PriceChangePercent7d >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent7d).ToString("N2", usd)%
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">30d</span>
        <span class="stat-value @(coin.PriceChangePercent30d >= 0 ? "text-success" : "text-danger")">
            @(coin.PriceChangePercent30d >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent30d).ToString("N2", usd)%
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">1yr</span>
        <span class="stat-value @(Model.PriceChange1yr.HasValue ? (Model.PriceChange1yr >= 0 ? "text-success" : "text-danger") : "")">
            @if (Model.PriceChange1yr.HasValue)
            {
                var c = Model.PriceChange1yr.Value;
                @(c >= 0 ? "▲" : "▼")
                @Math.Abs(c).ToString("N2", usd)
                @:%
            }
            else
            {
                <span style="color:var(--xmr-text-muted)">—</span>
            }
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">Market Cap</span>
        <span class="stat-value">
            @if (coin.MarketCapUsd >= 1_000_000_000_000m)
            {
                <text>$@((coin.MarketCapUsd / 1_000_000_000_000m).ToString("N2", usd))T</text>
            }
            else if (coin.MarketCapUsd >= 1_000_000_000m)
            {

                <text>$@((coin.MarketCapUsd / 1_000_000_000m).ToString("N2", usd))B</text>
            }
            else
            {

                <text>$@((coin.MarketCapUsd / 1_000_000m).ToString("N2", usd))M</text>
            }
        </span>
    </div>
    <div class="xmr-stat">
        <span class="stat-label">24h Volume</span>
        <span class="stat-value">
            @if (coin.TotalVolume >= 1_000_000_000m)
            {
                <text>$@((coin.TotalVolume / 1_000_000_000m).ToString("N2", usd))B</text>
            }
            else
            {

                <text>$@((coin.TotalVolume / 1_000_000m).ToString("N2", usd))M</text>
            }
        </span>
    </div>
</div>

<!-- Price chart -->
<div class="card mb-4" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Price (USD) — Last 365 Days</span>
        <div class="d-flex align-items-center gap-2">
            <button id="toggle-btn"
                    onclick="toggleMode()"
                    class="btn btn-outline-secondary btn-sm"
                    style="display:none;font-size:0.75rem">
                Show vs XMR
            </button>
            <span id="chart-status" style="font-size:0.78rem;color:var(--xmr-text-muted)">Loading...</span>
        </div>
    </div>
    <div class="card-body" style="position:relative;height:320px">
        <canvas id="price-chart"></canvas>
    </div>
</div>

<!-- vs XMR comparison -->
@if (!isXmr && xmr != null)
{
    <div class="card mb-4" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
        <div class="card-header">@coin.Symbol vs Monero (XMR)</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0" style="font-size:0.85rem">
                <tbody>
                    <tr>
                        <td style="color:var(--xmr-text-muted);width:50%">Price in XMR</td>
                        <td class="mono">
                            @if (priceInXmr >= 1)
                            {
                                <text>@priceInXmr.ToString("N4", usd) XMR</text>
                            }
                            else
                            {

                                <text>@priceInXmr.ToString("N8", usd) XMR</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">1 XMR buys</td>
                        <td class="mono">
                            @if (coinsPerXmr >= 1)
                            {
                                <text>@coinsPerXmr.ToString("N2", usd) @coin.Symbol</text>
                            }
                            else
                            {

                                <text>@coinsPerXmr.ToString("N8", usd) @coin.Symbol</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">Market Cap vs XMR</td>
                        <td class="mono">
                            @if (mcapRatio >= 1)
                            {
                                <span class="ratio-larger">@mcapRatio.ToString("N1", usd)× larger</span>
                            }
                            else
                            {

                                <span class="ratio-smaller">@((mcapRatio * 100).ToString("N1", usd))% of XMR</span>
                            }
                        </td>
                    </tr>
                    @{
                        void RenderVsXmrRow(string label, decimal? change, string symbol)
                        {
                            <tr>
                                <td style="color:var(--xmr-text-muted)">
                                    vs XMR (@label)
                                    <span style="font-size:0.75rem;color:var(--xmr-text-muted);display:block">
                                        Holding @symbol vs holding XMR
                                    </span>
                                </td>
                                <td class="mono">
                                    @if (change.HasValue)
                                    {
                                        var v = change.Value;
                                        <span class="@(v >= 0 ? "text-success" : "text-danger")">
                                            @(v >= 0 ? "▲" : "▼") @Math.Abs(v).ToString("N1", usd)%
                                        </span>
                                        <span style="font-size:0.8rem;color:var(--xmr-text-muted);margin-left:6px">
                                            @(v >= 0 ? $"{symbol} outperformed XMR" : $"XMR outperformed {symbol}")
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--xmr-text-muted)">Insufficient history</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    @{
                        RenderVsXmrRow("7d", Model.VsXmrChange7d, coin.Symbol);
                    }
                    @{
                        RenderVsXmrRow("30d", Model.VsXmrChange30d, coin.Symbol);
                    }
                    @{
                        RenderVsXmrRow("1yr", Model.VsXmrChange1yr, coin.Symbol);
                    }
                    <tr>
                        <td style="color:var(--xmr-text-muted)">Circulating Supply</td>
                        <td class="mono">@coin.CirculatingSupply.ToString("N0", usd) @coin.Symbol</td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">Max Supply</td>
                        <td class="mono">
                            @if (coin.MaxSupply.HasValue)
                            {
                                <text>@coin.MaxSupply.Value.ToString("N0", usd) @coin.Symbol</text>
                            }
                            else
                            {

                                <span style="color:var(--xmr-text-muted)">∞ (no cap)</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">24h High</td>
                        <td class="mono">
                            @if (coin.High24h >= 1)
                            {
                                <text>$@coin.High24h.ToString("N2", usd)</text>
                            }
                            else
                            {

                                <text>$@coin.High24h.ToString("N6", usd)</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">24h Low</td>
                        <td class="mono">
                            @if (coin.Low24h >= 1)
                            {
                                <text>$@coin.Low24h.ToString("N2", usd)</text>
                            }
                            else
                            {

                                <text>$@coin.Low24h.ToString("N6", usd)</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">All-Time High</td>
                        <td class="mono">
                            @if (coin.Ath >= 1)
                            {
                                <text>$@coin.Ath.ToString("N2", usd)</text>
                            }
                            else
                            {

                                <text>$@coin.Ath.ToString("N6", usd)</text>
                            }
                            <span class="@(coin.AthChangePercentage >= 0 ? "text-success" : "text-danger")" style="font-size:0.8rem;margin-left:6px">
                                (@coin.AthChangePercentage.ToString("N1", usd)%)
                            </span>
                        </td>
                    </tr>
                    @if (coin.AthDate != default)
                    {
                        <tr>
                            <td style="color:var(--xmr-text-muted)">ATH Date</td>
                            <td class="mono" style="color:var(--xmr-text-muted)">@coin.AthDate?.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                    <tr>
                        <td style="color:var(--xmr-text-muted)">Market Cap Rank</td>
                        <td class="mono">#@coin.MarketCapRank</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}

@if (isXmr)
{
    <div class="card mb-4" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
        <div class="card-header">Monero (XMR) Stats</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0" style="font-size:0.85rem">
                <tbody>
                    @{
                        var hasNode = MoneroSupplyDisplay.IsNodeSupplyFresh(coin);
                        var nodeSupply = hasNode ? coin.NodeSupply!.Value : 0m;
                        var nodeMarketCap = hasNode ? nodeSupply * coin.PriceUsd : 0m;
                    }

                    <tr>
                        <td style="color:var(--xmr-text-muted);width:50%">
                            Market Cap
                            @if (hasNode)
                            {
                                <span class="badge bg-success ms-1" style="font-size:0.65rem;font-weight:normal;vertical-align:middle">✓ node</span>
                            }
                        </td>
                        <td class="mono">
                            @if (hasNode)
                            {
                                <div>$@((nodeMarketCap / 1_000_000_000m).ToString("N2", usd))B</div>
                                <div style="font-size:0.75rem;color:var(--xmr-text-muted);margin-top:2px">
                                    CoinGecko: $@((coin.MarketCapUsd / 1_000_000_000m).ToString("N2", usd))B
                                </div>
                            }
                            else
                            {
                                <text>$@((coin.MarketCapUsd / 1_000_000_000m).ToString("N2", usd))B</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">
                            Circulating Supply
                            @if (hasNode)
                            {
                                <span class="badge bg-success ms-1" style="font-size:0.65rem;font-weight:normal;vertical-align:middle">✓ node</span>
                            }
                        </td>
                        <td class="mono">
                            @if (hasNode)
                            {
                                <div>@nodeSupply.ToString("N0", usd) XMR</div>
                                <div style="font-size:0.75rem;color:var(--xmr-text-muted);margin-top:2px">
                                    at block @coin.NodeSupplyHeight!.Value.ToString("N0", usd)
                                    · CoinGecko: @coin.CirculatingSupply.ToString("N0", usd) XMR
                                </div>
                            }
                            else
                            {
                                <text>@coin.CirculatingSupply.ToString("N0", usd) XMR</text>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">Max Supply</td>
                        <td class="mono">
                            @if (coin.MaxSupply.HasValue)
                            {
                                <text>@coin.MaxSupply.Value.ToString("N0", usd) XMR</text>
                            }
                            else
                            {
                                <span style="color:var(--xmr-text-muted)">∞ (no cap)</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">24h High</td>
                        <td class="mono">$@coin.High24h.ToString("N2", usd)</td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">24h Low</td>
                        <td class="mono">$@coin.Low24h.ToString("N2", usd)</td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">All-Time High</td>
                        <td class="mono">
                            $@coin.Ath.ToString("N2", usd)
                            <span class="@(coin.AthChangePercentage >= 0 ? "text-success" : "text-danger")" style="font-size:0.8rem;margin-left:6px">
                                (@coin.AthChangePercentage.ToString("N1", usd)%)
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--xmr-text-muted)">Market Cap Rank</td>
                        <td class="mono">#@coin.MarketCapRank</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}

@if (isXmr)
{
    <div class="card mb-4" ...><!-- existing XMR stats card --></div>

    <!-- NEW card below -->
    <div class="card mb-4" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
        <div class="card-header">How we calculate Monero's supply</div>
        <div class="card-body" style="font-size:0.85rem;line-height:1.6">
            <p style="margin-bottom:0.75rem">
                Most market cap sites pull Monero's circulating supply from an aggregator
                (CoinGecko, CoinMarketCap), which refreshes infrequently and can lag the real
                chain by hundreds of thousands of XMR. We compute the supply directly from the
                current block height using Monero's published emission formula.
            </p>

            <h6 style="margin-top:1.25rem;margin-bottom:0.5rem;color:var(--xmr-text)">The formula</h6>
            <pre style="background:var(--xmr-bg);padding:0.75rem;border-radius:4px;font-size:0.8rem;overflow-x:auto;color:var(--xmr-text);margin:0"><code>supply ≈ 18,132,009 + (current_height − 2,641,623) × 0.6</code></pre>
            <ul style="margin-top:0.75rem;margin-bottom:0.75rem;padding-left:1.25rem">
                <li><strong>18,132,009 XMR</strong> — approximate total emitted before tail emission began</li>
                <li><strong>Block 2,641,623</strong> — the block at which tail emission activated (≈ May 2022)</li>
                <li><strong>0.6 XMR per block</strong> — the fixed tail emission reward that continues forever</li>
            </ul>

            @if (MoneroSupplyDisplay.IsNodeSupplyFresh(coin) && coin.NodeSupplyHeight.HasValue)
            {
                <p style="margin-bottom:0.75rem">
                    <strong>At block @coin.NodeSupplyHeight.Value.ToString("N0", usd):</strong>
                    18,132,009 + (@coin.NodeSupplyHeight.Value.ToString("N0", usd) − 2,641,623) × 0.6 =
                    <span class="mono">@coin.NodeSupply!.Value.ToString("N0", usd) XMR</span>
                </p>
            }

            <h6 style="margin-top:1.25rem;margin-bottom:0.5rem;color:var(--xmr-text)">How we verify the block height</h6>
            <p style="margin-bottom:0.75rem">
                Our backend runs a full Monero node (via our self-hosted
                BTCPay Server)
                that is in constant sync with the Monero network. The block height reported above
                is read directly from our node every few minutes — not from any third-party
                aggregator or block explorer.
            </p>

            <h6 style="margin-top:1.25rem;margin-bottom:0.5rem;color:var(--xmr-text)">Caveats — why this is an estimate, not an exact figure</h6>
            <p style="margin-bottom:0.5rem">
                The formula above gives the supply from base block rewards only. It <em>does not</em>
                include transaction fees, which are also added to each coinbase transaction.
                Over 1M+ blocks since tail emission began, accumulated fees add roughly
                10,000–20,000 XMR to the true total.
            </p>
            <p style="margin-bottom:0">
                For the exact total (block rewards + all tx fees, summed from genesis),
                see <a href="https://moneroinflation.com" target="_blank" rel="noopener" style="color:var(--xmr-orange)">moneroinflation.com</a>,
                which runs the full Monero consensus code to verify every block's emission.
                Our number is typically within ~0.1% of theirs, and always closer to the truth
                than CoinGecko's (which commonly lags by hundreds of thousands of XMR).
            </p>

            <h6 style="margin-top:1.25rem;margin-bottom:0.5rem;color:var(--xmr-text)">Verify it yourself</h6>
            <ul style="margin:0;padding-left:1.25rem">
                <li>
                    <a href="https://www.getmonero.org/resources/moneropedia/tail-emission.html" target="_blank" rel="noopener" style="color:var(--xmr-orange)">
                        Monero's official tail emission documentation
                    </a>
                </li>
                <li>
                    <a href="https://github.com/monero-project/monero/blob/master/src/cryptonote_config.h" target="_blank" rel="noopener" style="color:var(--xmr-orange)">
                        Emission constants in the Monero source code
                    </a>
                </li>
                <li>
                    <a href="https://moneroinflation.com" target="_blank" rel="noopener" style="color:var(--xmr-orange)">
                        moneroinflation.com — independent full-node supply verifier
                    </a>
                </li>
                <li>
                    <a href="https://github.com/DangerousFreedom1984/monero_inflation_checker" target="_blank" rel="noopener" style="color:var(--xmr-orange)">
                        monero_inflation_checker — the tool behind moneroinflation.com
                    </a>
                </li>
            </ul>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/chart.umd.min.js"></script>
    <script>
        const coinGeckoId = '@coin.CoinGeckoId';
        const coinSymbol = '@coin.Symbol';
        const isXmr = coinSymbol === 'XMR';

        let chartInstance = null;
        let rawCoin = null;
        let rawXmr = null;
        let mode = 'price'; // 'price' | 'vs'

        function formatPrice(v) {
        if (v >= 1000) return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        if (v >= 1) return '$' + v.toFixed(2);
        if (v >= 0.01) return '$' + v.toFixed(4);
        return '$' + v.toFixed(8);
        }

        function normalize(series) {
        if (!series.length) return [];
        const base = series[0][1];
        if (!base) return series.map(p => [p[0], 0]);
        return series.map(p => [p[0], ((p[1] / base) - 1) * 100]);
        }

        function alignSeries(a, b) {
        const bMap = new Map(b.map(p => [new Date(p[0]).toDateString(), p[1]]));
        return a.map(p => {
        const key = new Date(p[0]).toDateString();
        return [p[0], bMap.get(key) ?? null];
        });
        }

        function buildChart(coinData, xmrData) {
        const ctx = document.getElementById('price-chart').getContext('2d');
        if (chartInstance) { chartInstance.destroy(); chartInstance = null; }

        const labels = coinData.map(p => {
        const d = new Date(p[0]);
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        });

        let datasets;

        if (mode === 'price' || isXmr) {
        // Price mode — XMR page orange, all other coins blue
        datasets = [{
        label: coinSymbol + ' Price (USD)',
        data: coinData.map(p => p[1]),
        borderColor: isXmr ? '#FF6600' : '#4a9eff',
        backgroundColor: isXmr ? 'rgba(255,102,0,0.08)' : 'rgba(74,158,255,0.08)',
        borderWidth: 1.5,
        pointRadius: 0,
        pointHoverRadius: 4,
        tension: 0.2,
        fill: true,
        yAxisID: 'y'
        }];
        } else {
        // vs XMR mode — XMR always orange, coin always blue
        const normCoin = normalize(coinData);
        const xmrAligned = alignSeries(coinData, xmrData);

        datasets = [
        {
        label: coinSymbol + ' % change',
        data: normCoin.map(p => p[1]),
        borderColor: '#4a9eff',
        backgroundColor: 'rgba(74,158,255,0.06)',
        borderWidth: 1.5,
        pointRadius: 0,
        pointHoverRadius: 4,
        tension: 0.2,
        fill: false,
        yAxisID: 'y'
        },
        {
        label: 'XMR % change',
        data: normalize(xmrAligned).map(p => p[1]),
        borderColor: '#FF6600',
        backgroundColor: 'rgba(255,102,0,0.06)',
        borderWidth: 1.5,
        pointRadius: 0,
        pointHoverRadius: 4,
        tension: 0.2,
        fill: false,
        yAxisID: 'y'
        }
        ];
        }

        const isVsMode = mode === 'vs' && !isXmr;

        chartInstance = new Chart(ctx, {
        type: 'line',
        data: { labels, datasets },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
        legend: { display: isVsMode, labels: { color: '#aaa', boxWidth: 12 } },
        tooltip: {
        callbacks: {
        label: ctx => {
        const v = ctx.parsed.y;
        if (v === null) return null;
        if (isVsMode) return ctx.dataset.label + ': ' + (v >= 0 ? '+' : '') + v.toFixed(2) + '%';
        return formatPrice(v);
        }
        }
        }
        },
        scales: {
        x: {
        ticks: { color: '#888', maxTicksLimit: 12, maxRotation: 0 },
        grid: { color: 'rgba(255,255,255,0.05)' }
        },
        y: {
        ticks: {
        color: '#888',
        callback: v => isVsMode
        ? (v >= 0 ? '+' : '') + v.toFixed(0) + '%'
        : (v >= 1000 ? '$' + (v / 1000).toFixed(1) + 'k'
        : v >= 1 ? '$' + v.toFixed(2)
        : v >= 0.01 ? '$' + v.toFixed(4)
        : '$' + v.toFixed(6))
        },
        grid: { color: 'rgba(255,255,255,0.05)' }
        }
        }
        }
        });
        }

        async function loadChart() {
        document.getElementById('chart-status').textContent = 'Loading...';
        try {
        const [coinRes, xmrRes] = await Promise.all([
        fetch('/api/coin/' + coinGeckoId + '/chart'),
        isXmr ? Promise.resolve(null) : fetch('/api/coin/monero/chart')
        ]);

        if (!coinRes.ok) throw new Error('fetch failed');
        const coinJson = await coinRes.json();
        rawCoin = Array.isArray(coinJson) ? coinJson : (coinJson.prices ?? []);

        if (xmrRes) {
        const xmrJson = await xmrRes.json();
        rawXmr = Array.isArray(xmrJson) ? xmrJson : (xmrJson.prices ?? []);
        }

        if (!rawCoin.length) {
        document.getElementById('chart-status').textContent = 'No data available';
        return;
        }

        document.getElementById('chart-status').textContent = rawCoin.length + ' days';
        buildChart(rawCoin, rawXmr ?? []);

        if (!isXmr) {
        document.getElementById('toggle-btn').style.display = 'inline-block';
        }
        } catch (e) {
        document.getElementById('chart-status').textContent = 'Chart unavailable';
        }
        }

        function toggleMode() {
        mode = mode === 'price' ? 'vs' : 'price';
        const btn = document.getElementById('toggle-btn');
        btn.textContent = mode === 'vs' ? 'Show Price (USD)' : 'Show vs XMR';
        buildChart(rawCoin, rawXmr ?? []);
        }

        loadChart();
    </script>
}
