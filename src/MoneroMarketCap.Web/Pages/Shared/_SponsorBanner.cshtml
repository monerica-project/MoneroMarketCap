@{
    var rotateInterval = (ViewBag.SponsorRotateIntervalSeconds != null
        ? (int)ViewBag.SponsorRotateIntervalSeconds > 0 ? (int)ViewBag.SponsorRotateIntervalSeconds : 30
        : 30) * 1000;
}

<div class="sponsor-banner mb-3" id="sponsor-banner">
    <span class="sponsor-label">Sponsored by <a href="https://monerica.com" target="_blank" rel="noopener" style="color:var(--xmr-orange);text-decoration:none">Monerica</a></span>
    <div class="sponsor-track" id="sponsor-track">
        <div class="sponsor-loading" id="sponsor-loading">Loading sponsors...</div>
    </div>
</div>

<script>
    (function() {
        const ROTATE_MS = @rotateInterval;
        const SPONSORS_PER_PAGE = 3;
        const typeOrder = { 'MainSponsor': 0, 'CategorySponsor': 1, 'SubcategorySponsor': 2 };

        let sponsors = [];
        let sponsorPage = 0;
        let sponsorTimer = null;

        function sponsorTypeBadge(type) {
            if (type === 'MainSponsor') return '<span class="sp-badge sp-main">Main</span>';
            if (type === 'CategorySponsor') return '<span class="sp-badge sp-cat">Category</span>';
            if (type === 'SubcategorySponsor') return '<span class="sp-badge sp-sub">Subcategory</span>';
            return '';
        }

        function truncateWords(text, maxChars) {
            if (!text || text.length <= maxChars) return text || '';
            const cut = text.substring(0, maxChars);
            const lastSpace = cut.lastIndexOf(' ');
            return (lastSpace > 0 ? cut.substring(0, lastSpace) : cut) + '…';
        }

        function renderSponsors() {
            const track = document.getElementById('sponsor-track');
            if (!track || sponsors.length === 0) return;
            const start = sponsorPage * SPONSORS_PER_PAGE;
            const slice = sponsors.slice(start, start + SPONSORS_PER_PAGE);
            track.style.opacity = '0';
            setTimeout(() => {
                track.innerHTML = slice.map(s => `
                        <a class="sponsor-card" href="${s.link}" target="_blank" rel="noopener sponsored">
                            ${sponsorTypeBadge(s.sponsorshipType)}
                            <span class="sp-name">${s.name}</span>
                            <span class="sp-desc">${truncateWords(s.description, 120)}</span>
                        </a>
                    `).join('');
                track.style.opacity = '1';
            }, 200);
            sponsorPage = (start + SPONSORS_PER_PAGE >= sponsors.length) ? 0 : sponsorPage + 1;
        }

        async function loadSponsors() {
            try {
                const res = await fetch('/api/sponsors');
                if (!res.ok) return;
                const data = await res.json();
                sponsors = data.sort((a, b) => {
                    const tDiff = (typeOrder[a.sponsorshipType] ?? 9) - (typeOrder[b.sponsorshipType] ?? 9);
                    if (tDiff !== 0) return tDiff;
                    return new Date(b.expirationDate) - new Date(a.expirationDate);
                });
                document.getElementById('sponsor-loading')?.remove();
                renderSponsors();
                if (sponsorTimer) clearInterval(sponsorTimer);
                sponsorTimer = setInterval(renderSponsors, ROTATE_MS);
            } catch (e) {
                const loading = document.getElementById('sponsor-loading');
                if (loading) loading.style.display = 'none';
            }
        }

        loadSponsors();
    })();
</script>
