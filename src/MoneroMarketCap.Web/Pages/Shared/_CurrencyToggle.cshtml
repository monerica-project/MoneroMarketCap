@using MoneroMarketCap.Services.Models
@using MoneroMarketCap.Web.Helpers
@{
    var current = CurrencyResolver.Resolve(Context);
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<form method="post" asp-page="/SetCurrency" style="display:inline" class="currency-toggle-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <label for="currency-select" class="visually-hidden">Display currency</label>
    <select id="currency-select"
            name="code"
            class="form-select form-select-sm currency-toggle-select"
            onchange="this.form.submit()"
            aria-label="Display currency">
        @foreach (var c in CurrencyCatalog.All)
        {
            <option value="@c.Code" selected="@(c.Code == current.Code)">
                @c.Code @c.Symbol
            </option>
        }
    </select>
    <noscript>
        <button type="submit" class="btn btn-sm btn-outline-secondary">Set</button>
    </noscript>
</form>
