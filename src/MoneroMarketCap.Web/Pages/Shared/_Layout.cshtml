@using MoneroMarketCap.Data.Constants
@using MoneroMarketCap.Data.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MoneroMarketCap</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light border-bottom mb-3">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">MoneroMarketCap</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Portfolios/Index">My Portfolios</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole(RoleNames.Admin) || User.IsInRole(RoleNames.Moderator))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Admin/Index">&#x2699; Admin</a>
                                </li>
                            }
                            <li class="nav-item">
                                <span class="nav-link fw-bold" style="color:var(--xmr-orange)">
                                    &#x1F464; @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Settings">&#x2699; Settings</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; @DateTime.UtcNow.Year - MoneroMarketCap
            &nbsp;|&nbsp;
            <a asp-page="/Contact" style="color:var(--xmr-text-muted);font-size:0.85rem">Contact</a>
            &nbsp;|&nbsp;
            <a href="http://7vpxaew4op4jy3ltgmdyj6qwmjdkb27mpjkqnwozjxdk63lfj6q7fhad.onion"
               style="color:var(--xmr-text-muted);font-size:0.85rem"
               title="Available on Tor">&#x1F9C5; .onion</a>
            &nbsp;|&nbsp;
            <a href="https://github.com/monerica-project/MoneroMarketCap" target="_blank">Code</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
