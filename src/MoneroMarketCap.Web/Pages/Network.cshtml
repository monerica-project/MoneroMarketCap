@page "/network"
@{
    ViewData["Title"] = "The Monerica Network";
    ViewData["MetaDescription"] = "The Monerica network — a family of independent, privacy-respecting Monero projects: Monerica, Monero Academy, Monero Price Now, Monero Market Cap and Monero Shame List.";
}

<h2>The Monerica Network</h2>

<p>
    MoneroMarketCap is part of the <strong>Monerica network</strong> — a family of independent,
    privacy-respecting projects for the Monero community. Each site references the others, so you can
    always find your way around.
</p>

<h3 style="color:var(--xmr-orange);margin-top:1.5rem;">Sites in the network</h3>

<ul style="line-height:1.8;">
    <li>
        <a href="https://monerica.com" target="_blank" rel="noopener">Monerica.com</a>
        — the Monero circular-economy directory: merchants and services that accept XMR.
    </li>
    <li>
        <a href="https://moneroacademy.com" target="_blank" rel="noopener">MoneroAcademy.com</a>
        — free Monero education: courses, lessons and quizzes from beginner to advanced.
    </li>
    <li>
        <a href="https://moneropricenow.com" target="_blank" rel="noopener">MoneroPriceNow.com</a>
        — the live Monero (XMR) price, clean and tracker-free.
    </li>
    <li>
        <strong>MoneroMarketCap.com</strong>
        <span style="color:var(--xmr-text-muted);">— you are here.</span> Monero market data, supply and statistics.
    </li>
    <li>
        <a href="https://moneroshamelist.com" target="_blank" rel="noopener">MoneroShameList.com</a>
        — a watchlist of privacy-focused companies that don't yet accept Monero.
    </li>
</ul>

<h3 style="color:var(--xmr-orange);margin-top:1.5rem;">Follow the project</h3>

<ul style="line-height:1.8;">
