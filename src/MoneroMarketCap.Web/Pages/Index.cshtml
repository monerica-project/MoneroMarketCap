@page
@using MoneroMarketCap.Services.Display
@model MoneroMarketCap.Pages.IndexModel
@{
    ViewData["Title"] = "Market Cap — Valued in Monero";
    ViewBag.SponsorRotateIntervalSeconds = Model.SponsorRotateIntervalSeconds;
}

<partial name="_SponsorBanner" />

@if (Model.Monero != null)
{
    var xmr = Model.Monero;
    <div class="xmr-stat-bar mb-4" style="display:flex;gap:1.5rem;flex-wrap:wrap">
        <div class="xmr-stat" style="flex:1;min-width:160px;padding:1rem 1.25rem">
            <span class="stat-label">XMR Price</span>
            <span class="stat-value" id="xmr-price">@FormatUsd(xmr.PriceUsd)</span>
            <span id="xmr-change-24h" class="stat-change @(xmr.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
                @(xmr.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent24h).ToString("N2")% 24h
            </span>
        </div>
        <div class="xmr-stat" style="flex:1;min-width:160px;padding:1rem 1.25rem">
            <span class="stat-label">
                Market Cap
                @if (MoneroSupplyDisplay.IsNodeVerified(xmr))
                {
                    <span class="badge bg-success ms-1" style="font-size:0.6rem;font-weight:normal;vertical-align:middle" title="Circulating supply verified by our full Monero node">✓ node</span>
                }
            </span>
            <span class="stat-value" id="xmr-mcap">@FormatLarge(MoneroSupplyDisplay.EffectiveMarketCapUsd(xmr))</span>
            <span id="xmr-rank" class="stat-change" style="color:var(--xmr-text-muted)">Rank #@xmr.MarketCapRank</span>
        </div>
        <div class="xmr-stat" style="flex:2;min-width:320px;padding:1rem 1.25rem">
            <span class="stat-label">Price Change</span>
            <div class="price-changes" style="display:flex;gap:1.25rem;flex-wrap:wrap;margin-top:0.35rem">
                <span class="change-row">
                    <span class="change-label">1h</span>
                    <span id="xmr-1h" class="@(xmr.PriceChangePercent1h >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent1h >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent1h).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">24h</span>
                    <span id="xmr-24h" class="@(xmr.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent24h).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">7d</span>
                    <span id="xmr-7d" class="@(xmr.PriceChangePercent7d >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent7d >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent7d).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">30d</span>
                    <span id="xmr-30d" class="@(xmr.PriceChangePercent30d >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent30d >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent30d).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">1y</span>
                    <span id="xmr-1y" class="@(xmr.PriceChangePercent1y >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent1y >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent1y).ToString("N2")%
                    </span>
                </span>
            </div>
        </div>
    </div>
}

<div class="table-meta">
    <span>
        <span style="color:var(--xmr-text-muted)">Data updated:</span>
        <span id="last-updated-bar"
              title="@(Model.Coins.Any() ? Model.Coins.Max(c => c.UpdatedAt).ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "")"
              style="cursor:default">
            @(Model.Coins.Any() ? Model.Coins.Max(c => c.UpdatedAt).ToString("HH:mm:ss") + " UTC" : "pending...")
        </span>
    </span>
    <span>
        <span style="color:var(--xmr-text-muted)">Next update in:</span>
        <span id="countdown-bar">60</span>s
    </span>
</div>

@if (!Model.Coins.Any())
{
    <div class="empty-state">
        <p>No coin data yet.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table market-table" style="font-size:0.82rem">
            <thead>
                <tr>
                    <th style="width:2rem;cursor:pointer;user-select:none" data-sort="mcap"># <span class="sort-indicator">▼</span></th>
                    <th style="cursor:pointer;user-select:none" data-sort="name">Coin <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="price">Price (USD) <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="xmr-price">Price (XMR) <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="change">24h % (USD) <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="xmr-change">24h % (XMR) <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="mcap">Market Cap <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="ratio">vs XMR <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="supply">Supply <span class="sort-indicator"></span></th>
                    <th class="text-end" style="cursor:pointer;user-select:none" data-sort="buys">1 XMR buys <span class="sort-indicator"></span></th>
                </tr>
            </thead>
            <tbody>
                @{
                    var xmrEffectiveMcap = Model.Monero != null ? MoneroSupplyDisplay.EffectiveMarketCapUsd(Model.Monero) : 0m;
                }
                @foreach (var coin in Model.Coins.OrderByDescending(c => MoneroSupplyDisplay.EffectiveMarketCapUsd(c)))
                {
                    var effectiveMcap = MoneroSupplyDisplay.EffectiveMarketCapUsd(coin);
                    var effectiveSupply = MoneroSupplyDisplay.EffectiveCirculatingSupply(coin);
                    var isNodeVerified = MoneroSupplyDisplay.IsNodeVerified(coin);

                    var priceInXmr = Model.Monero != null && Model.Monero.PriceUsd > 0
                        ? coin.PriceUsd / Model.Monero.PriceUsd : 0;
                    var mcapRatio = xmrEffectiveMcap > 0
                        ? effectiveMcap / xmrEffectiveMcap : 0;
                    var coinsPerXmr = coin.PriceUsd > 0 && Model.Monero != null
                        ? Model.Monero.PriceUsd / coin.PriceUsd : 0;
                    // 24h change denominated in XMR: how much the coin moved relative to XMR
                    var xmrChange24h = Model.Monero != null
                        ? ((1m + coin.PriceChangePercent24h / 100m) / (1m + Model.Monero.PriceChangePercent24h / 100m) - 1m) * 100m
                        : 0m;
                    bool isXmr = coin.Symbol.ToUpper() == "XMR";

                    <tr class="@(isXmr ? "xmr-row" : "")"
                        data-symbol="@coin.Symbol"
                        data-name="@coin.Symbol.ToLower()"
                        data-price="@coin.PriceUsd"
                        data-xmr-price="@priceInXmr"
                        data-change="@coin.PriceChangePercent24h"
                        data-xmr-change="@xmrChange24h"
                        data-mcap="@effectiveMcap"
                        data-ratio="@mcapRatio"
                        data-supply="@effectiveSupply"
                        data-buys="@coinsPerXmr"
                        data-node-verified="@(isNodeVerified ? "true" : "false")">
                        <td class="rank-cell cell-rank"></td>
                        <td>
                            <div class="coin-name-cell">
                                @if (!string.IsNullOrEmpty(coin.ImageUrl))
                                {
                                    <a href="/coins/@coin.Symbol.ToLower()">
                                        <img src="@coin.ImageUrl" width="20" height="20" style="border-radius:50%;flex-shrink:0" />
                                    </a>
                                }
                                <a href="/coins/@coin.Symbol.ToLower()" class="coin-symbol" style="color:inherit;text-decoration:none">@coin.Symbol</a>
                                <a href="/coins/@coin.Symbol.ToLower()" class="coin-name d-none d-lg-inline" style="color:var(--xmr-text-muted);text-decoration:none">@coin.Name</a>
                                @if (isXmr)
                                {
                                    <span class="xmr-badge">base</span>
                                }
                            </div>
                        </td>
                        <td class="text-end mono cell-price">@FormatUsd(coin.PriceUsd)</td>
                        <td class="text-end mono xmr-val cell-xmr-price">
                            @if (isXmr)
                            {
                                <span>1 XMR</span>
                            }
                            else if (priceInXmr >= 1)
                            {
                                @($"{priceInXmr:N4} XMR")
                            }
                            else
                            {
                                @($"{priceInXmr:N8} XMR")
                            }
                        </td>
                        <td class="text-end mono cell-change @(coin.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
                            @(coin.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent24h).ToString("N2")%
                        </td>
                        <td class="text-end mono cell-xmr-change @(isXmr ? "" : xmrChange24h >= 0 ? "text-success" : "text-danger")">
                            @if (isXmr)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @($"{(xmrChange24h >= 0 ? "▲" : "▼")} {Math.Abs(xmrChange24h).ToString("N2")}%")
                            }
                        </td>
                        <td class="text-end mono cell-mcap">
                            @FormatLarge(effectiveMcap)
                            @if (isNodeVerified)
                            {
                                <span class="badge bg-success ms-1" style="font-size:0.6rem;font-weight:normal;vertical-align:middle" title="Verified by our full node">✓</span>
                            }
                        </td>
                        <td class="text-end cell-ratio" style="white-space:nowrap">
                            @if (isXmr)
                            {
                                <span class="ratio-base">base</span>
                            }
                            else if (mcapRatio >= 1)
                            {
                                <span class="ratio-larger">@mcapRatio.ToString("N1")×</span>
                            }
                            else
                            {
                                <span class="ratio-smaller">@((mcapRatio * 100).ToString("N1"))%</span>
                            }
                        </td>
                        <td class="text-end mono cell-supply">
                            @FormatUnits(effectiveSupply)
                            @if (isNodeVerified)
                            {
                                <span class="badge bg-success ms-1" style="font-size:0.6rem;font-weight:normal;vertical-align:middle" title="Verified by our full node">✓</span>
                            }
                        </td>
                        <td class="text-end mono xmr-val cell-buys" style="white-space:nowrap">
                            @if (!isXmr)
                            {
                                @(coinsPerXmr >= 1
                                    ? $"{coinsPerXmr:N2} {coin.Symbol}"
                                    : $"{coinsPerXmr:N8} {coin.Symbol}")
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}


<partial name="_SponsorList" />


@functions {
    static readonly System.Globalization.CultureInfo _usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");

    string FormatUsd(decimal value)
    {
        if (value >= 1) return "$" + value.ToString("N2", _usd);
        if (value >= 0.01m) return "$" + value.ToString("N4", _usd);
        if (value >= 0.0001m) return "$" + value.ToString("N6", _usd);
        return "$" + value.ToString("N8", _usd);
    }

    string FormatLarge(decimal value) => value switch
    {
        >= 1_000_000_000_000m => "$" + (value / 1_000_000_000_000m).ToString("N2", _usd) + "T",
        >= 1_000_000_000m => "$" + (value / 1_000_000_000m).ToString("N2", _usd) + "B",
        >= 1_000_000m => "$" + (value / 1_000_000m).ToString("N2", _usd) + "M",
        >= 1_000m => "$" + (value / 1_000m).ToString("N2", _usd) + "K",
        _ => "$" + value.ToString("N2", _usd)
    };

    string FormatUnits(decimal value) => value switch
    {
        >= 1_000_000_000m => (value / 1_000_000_000m).ToString("N2", _usd) + "B",
        >= 1_000_000m => (value / 1_000_000m).ToString("N2", _usd) + "M",
        >= 1_000m => (value / 1_000m).ToString("N2", _usd) + "K",
        _ => value.ToString("N0", _usd)
    };
}

@section Scripts {
    <script>
        function formatLarge(v) {
            if (v >= 1e12) return '$' + (v / 1e12).toFixed(2) + 'T';
            if (v >= 1e9) return '$' + (v / 1e9).toFixed(2) + 'B';
            if (v >= 1e6) return '$' + (v / 1e6).toFixed(2) + 'M';
            if (v >= 1e3) return '$' + (v / 1e3).toFixed(2) + 'K';
            return '$' + v.toFixed(2);
        }
        function formatUnits(v) {
            if (v >= 1e9) return (v / 1e9).toFixed(2) + 'B';
            if (v >= 1e6) return (v / 1e6).toFixed(2) + 'M';
            if (v >= 1e3) return (v / 1e3).toFixed(2) + 'K';
            return Math.round(v).toLocaleString();
        }
        function formatPrice(v) {
            if (v >= 1) return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            if (v >= 0.01) return '$' + v.toFixed(4);
            if (v >= 0.0001) return '$' + v.toFixed(6);
            return '$' + v.toFixed(8);
        }
        function formatXmrPrice(price, xmrPrice) {
            if (!xmrPrice) return '—';
            const r = price / xmrPrice;
            return r >= 1 ? r.toFixed(4) + ' XMR' : r.toFixed(8) + ' XMR';
        }
        function formatCoinsPerXmr(price, xmrPrice, symbol) {
            if (!price) return '—';
            const r = xmrPrice / price;
            return r >= 1 ? r.toFixed(2) + ' ' + symbol : r.toFixed(8) + ' ' + symbol;
        }
        function formatRatio(mcap, xmrMcap) {
            const r = mcap / xmrMcap;
            if (r >= 1) return { text: r.toFixed(1) + '×', cls: 'ratio-larger' };
            return { text: (r * 100).toFixed(1) + '%', cls: 'ratio-smaller' };
        }
        function formatChangeCell(val) {
            const up = val >= 0;
            return {
                text: (up ? '▲ ' : '▼ ') + Math.abs(val).toFixed(2) + '%',
                cls: 'text-end mono ' + (up ? 'text-success' : 'text-danger')
            };
        }

        // Badge HTML reused when preserving node-verified markers across refreshes.
        const VERIFIED_BADGE = ' <span class="badge bg-success ms-1" style="font-size:0.6rem;font-weight:normal;vertical-align:middle" title="Verified by our full node">✓</span>';

        // --- Sort state ---
        let sortCol = 'mcap';
        let sortDir = 'desc';

        function applySort() {
            const tbody = document.querySelector('.market-table tbody');
            if (!tbody) return;

            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                if (sortCol === 'name') {
                    const aVal = a.dataset.name || '';
                    const bVal = b.dataset.name || '';
                    return sortDir === 'asc' ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
                }
                // Map sort key to dataset camelCase key
                const dsKey = {
                    'mcap': 'mcap',
                    'price': 'price',
                    'xmr-price': 'xmrPrice',
                    'change': 'change',
                    'xmr-change': 'xmrChange',
                    'ratio': 'ratio',
                    'supply': 'supply',
                    'buys': 'buys'
                }[sortCol] || sortCol;
                const aVal = parseFloat(a.dataset[dsKey]) || 0;
                const bVal = parseFloat(b.dataset[dsKey]) || 0;
                return sortDir === 'asc' ? aVal - bVal : bVal - aVal;
            });

            rows.forEach((row, idx) => {
                const rankCell = row.querySelector('.cell-rank');
                if (rankCell) rankCell.textContent = idx + 1;
                tbody.appendChild(row);
            });

            document.querySelectorAll('.market-table thead th').forEach(th => {
                const indicator = th.querySelector('.sort-indicator');
                if (!indicator) return;
                indicator.textContent = th.dataset.sort === sortCol
                    ? (sortDir === 'asc' ? '▲' : '▼')
                    : '';
            });
        }

        document.querySelectorAll('.market-table thead th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (sortCol === col) {
                    sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                } else {
                    sortCol = col;
                    sortDir = col === 'name' ? 'asc' : 'desc';
                }
                applySort();
            });
        });

        applySort();

        async function refreshPrices() {
            try {
                const res = await fetch('/api/Prices');
                if (!res.ok) return;
                const coins = await res.json();
                const xmr = coins.find(c => c.symbol === 'XMR');
                if (!xmr) return;

                // Compute effective (node-verified-when-fresh) values on the client.
                // Falls back to CoinGecko values if the API doesn't yet expose node fields.
                const FRESHNESS_MS = 30 * 60 * 1000;
                function isNodeFresh(c) {
                    if (!c || !c.nodeSupply || !c.nodeSupplyUpdatedAt) return false;
                    const age = Date.now() - new Date(c.nodeSupplyUpdatedAt).getTime();
                    return age < FRESHNESS_MS;
                }
                function effectiveMcap(c) {
                    return isNodeFresh(c) && c.priceUsd > 0 ? c.nodeSupply * c.priceUsd : c.marketCapUsd;
                }
                function effectiveSupply(c) {
                    return isNodeFresh(c) ? c.nodeSupply : c.circulatingSupply;
                }

                const xmrEffectiveMcap = effectiveMcap(xmr);

                const xmrChangeHelper = (id, val) => {
                    const el = document.getElementById(id);
                    if (!el) return;
                    const up = val >= 0;
                    el.textContent = (up ? '▲ ' : '▼ ') + Math.abs(val).toFixed(2) + '%';
                    el.className = up ? 'text-success' : 'text-danger';
                };
                xmrChangeHelper('xmr-1h', xmr.priceChangePercent1h);
                xmrChangeHelper('xmr-24h', xmr.priceChangePercent24h);
                xmrChangeHelper('xmr-7d', xmr.priceChangePercent7d);
                xmrChangeHelper('xmr-30d', xmr.priceChangePercent30d);
                xmrChangeHelper('xmr-1y', xmr.priceChangePercent1y);

                const priceEl = document.getElementById('xmr-price');
                if (priceEl) priceEl.textContent = formatPrice(xmr.priceUsd);
                const mcapEl = document.getElementById('xmr-mcap');
                if (mcapEl) mcapEl.textContent = formatLarge(xmrEffectiveMcap);
                const rankEl = document.getElementById('xmr-rank');
                if (rankEl) rankEl.textContent = 'Rank #' + xmr.marketCapRank;

                coins.forEach(coin => {
                    const row = document.querySelector('tr[data-symbol="' + coin.symbol + '"]');
                    if (!row) return;
                    const isXmr = coin.symbol === 'XMR';

                    const coinEffectiveMcap = effectiveMcap(coin);
                    const coinEffectiveSupply = effectiveSupply(coin);

                    const priceInXmr = xmr.priceUsd > 0 ? coin.priceUsd / xmr.priceUsd : 0;
                    const mcapRatio = xmrEffectiveMcap > 0 ? coinEffectiveMcap / xmrEffectiveMcap : 0;
                    const coinsPerXmr = coin.priceUsd > 0 ? xmr.priceUsd / coin.priceUsd : 0;
                    const xmrChange24h = ((1 + coin.priceChangePercent24h / 100) / (1 + xmr.priceChangePercent24h / 100) - 1) * 100;

                    // Keep the data-node-verified attribute current based on live freshness.
                    // If the API doesn't return node fields yet, preserve the server-rendered value.
                    if (coin.nodeSupply !== undefined) {
                        row.dataset.nodeVerified = isNodeFresh(coin) ? 'true' : 'false';
                    }
                    const isVerified = row.dataset.nodeVerified === 'true';

                    // Update data attributes
                    row.dataset.price = coin.priceUsd;
                    row.dataset.xmrPrice = priceInXmr;
                    row.dataset.change = coin.priceChangePercent24h;
                    row.dataset.xmrChange = xmrChange24h;
                    row.dataset.mcap = coinEffectiveMcap;
                    row.dataset.ratio = mcapRatio;
                    row.dataset.supply = coinEffectiveSupply;
                    row.dataset.buys = coinsPerXmr;

                    // Update display cells
                    const priceCell = row.querySelector('.cell-price');
                    if (priceCell) priceCell.textContent = formatPrice(coin.priceUsd);

                    const xmrPriceCell = row.querySelector('.cell-xmr-price');
                    if (xmrPriceCell) xmrPriceCell.textContent = isXmr ? '1 XMR' : formatXmrPrice(coin.priceUsd, xmr.priceUsd);

                    const changeCell = row.querySelector('.cell-change');
                    if (changeCell) {
                        const f = formatChangeCell(coin.priceChangePercent24h);
                        changeCell.textContent = f.text;
                        changeCell.className = f.cls + ' cell-change';
                    }

                    const xmrChangeCell = row.querySelector('.cell-xmr-change');
                    if (xmrChangeCell) {
                        if (isXmr) {
                            xmrChangeCell.textContent = '—';
                            xmrChangeCell.className = 'text-end mono cell-xmr-change text-muted';
                        } else {
                            const f = formatChangeCell(xmrChange24h);
                            xmrChangeCell.textContent = f.text;
                            xmrChangeCell.className = f.cls + ' cell-xmr-change';
                        }
                    }

                    // Preserve the ✓ badge when node-verified.
                    const mcapCell = row.querySelector('.cell-mcap');
                    if (mcapCell) {
                        mcapCell.innerHTML = formatLarge(coinEffectiveMcap) + (isVerified ? VERIFIED_BADGE : '');
                    }

                    const ratioCell = row.querySelector('.cell-ratio');
                    if (ratioCell && !isXmr) {
                        const r = formatRatio(coinEffectiveMcap, xmrEffectiveMcap);
                        ratioCell.innerHTML = '<span class="' + r.cls + '">' + r.text + '</span>';
                    }

                    const supplyCell = row.querySelector('.cell-supply');
                    if (supplyCell) {
                        supplyCell.innerHTML = formatUnits(coinEffectiveSupply) + (isVerified ? VERIFIED_BADGE : '');
                    }

                    const buysCell = row.querySelector('.cell-buys');
                    if (buysCell) buysCell.textContent = isXmr ? '—' : formatCoinsPerXmr(coin.priceUsd, xmr.priceUsd, coin.symbol);
                });

                applySort();
            } catch (e) {
                console.error('Price refresh failed:', e);
            }
        }

        let seconds = 60;
        const countdownBar = document.getElementById('countdown-bar');
        const lastUpdatedBar = document.getElementById('last-updated-bar');
        setInterval(() => {
            seconds--;
            if (countdownBar) countdownBar.textContent = seconds;
            if (seconds <= 0) {
                seconds = 60;
                refreshPrices().then(() => {
                    const now = new Date();
                    const timeStr = now.toUTCString().split(' ')[4] + ' UTC';
                    if (lastUpdatedBar) {
                        lastUpdatedBar.textContent = timeStr;
                        lastUpdatedBar.title = now.toUTCString();
                    }
                });
            }
        }, 1000);
    </script>
}
