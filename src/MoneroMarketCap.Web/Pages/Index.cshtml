@page
@using MoneroMarketCap.Services.Display
@using MoneroMarketCap.Services.Models
@using MoneroMarketCap.Web.Helpers
@model MoneroMarketCap.Pages.IndexModel
@{
    ViewData["Title"] = $"Market Cap — Valued in Monero ({Model.Currency.Code})";
    ViewBag.SponsorRotateIntervalSeconds = Model.SponsorRotateIntervalSeconds;
    var cur = Model.Currency;
    var rate = Model.RatePerUsd;
}

<partial name="_SponsorBanner" />

@if (Model.Monero != null)
{
    var xmr = Model.Monero;
    <div class="xmr-stat-bar mb-4">
        <div class="xmr-stat">
            <span class="stat-label">XMR Price</span>
            <span class="stat-value" id="xmr-price">@MoneyFormatter.FormatPrice(xmr.PriceUsd, cur, rate)</span>
            <span id="xmr-change-24h" class="stat-change @(xmr.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
                @(xmr.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent24h).ToString("N2")% 24h
            </span>
        </div>
        <div class="xmr-stat">
            <span class="stat-label">Market Cap</span>
            <span class="stat-value" id="xmr-mcap">@MoneyFormatter.FormatLarge(MoneroSupplyDisplay.EffectiveMarketCapUsd(xmr), cur, rate)</span>
            <span id="xmr-rank" class="stat-change text-muted">Rank #@xmr.MarketCapRank</span>
        </div>
        <div class="xmr-stat xmr-stat--wide">
            <span class="stat-label">Price Change</span>
            <div class="price-changes">
                <span class="change-row">
                    <span class="change-label">1h</span>
                    <span id="xmr-1h" class="@(xmr.PriceChangePercent1h >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent1h >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent1h).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">24h</span>
                    <span id="xmr-24h" class="@(xmr.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent24h).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">7d</span>
                    <span id="xmr-7d" class="@(xmr.PriceChangePercent7d >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent7d >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent7d).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">30d</span>
                    <span id="xmr-30d" class="@(xmr.PriceChangePercent30d >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent30d >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent30d).ToString("N2")%
                    </span>
                </span>
                <span class="change-row">
                    <span class="change-label">1y</span>
                    <span id="xmr-1y" class="@(xmr.PriceChangePercent1y >= 0 ? "text-success" : "text-danger")">
                        @(xmr.PriceChangePercent1y >= 0 ? "▲" : "▼") @Math.Abs(xmr.PriceChangePercent1y).ToString("N2")%
                    </span>
                </span>
            </div>
        </div>
        @{
            // Best/worst performer vs XMR over 7d, excluding XMR itself.
            // Currency-independent: percentages don't change with FX.
            var performers = Model.Coins
                .Where(c => c.Symbol.ToUpper() != "XMR"
                         && Model.Monero != null
                         && Model.Monero.PriceChangePercent7d != -100m
                         && c.MarketCapUsd > 100_000_000m)
                .Select(c => new
                {
                    Coin = c,
                    VsXmr = ((1m + c.PriceChangePercent7d / 100m)
                           / (1m + Model.Monero!.PriceChangePercent7d / 100m) - 1m) * 100m
                })
                .ToList();

            var bestVsXmr = performers.OrderByDescending(x => x.VsXmr).FirstOrDefault();
            var worstVsXmr = performers.OrderBy(x => x.VsXmr).FirstOrDefault();
        }

        @if (bestVsXmr != null && worstVsXmr != null)
        {
            <div class="xmr-stat xmr-stat--med">
                <span class="stat-label">vs XMR (7d)</span>
                <div class="vs-xmr-row">
                    <a href="/coins/@bestVsXmr.Coin.Symbol.ToLower()" class="vs-xmr-link">
                        <div class="vs-xmr-body">
                            <span class="vs-xmr-label">Best</span>
                            <div class="vs-xmr-value" id="vs-xmr-best">
                                @if (!string.IsNullOrEmpty(bestVsXmr.Coin.ImageUrl))
                                {
                                    <img src="@bestVsXmr.Coin.ImageUrl" width="18" height="18" class="coin-icon" />
                                }
                                <span class="vs-xmr-symbol">@bestVsXmr.Coin.Symbol</span>
                                <span class="text-success mono vs-xmr-pct">
                                    ▲ @bestVsXmr.VsXmr.ToString("N2")%
                                </span>
                            </div>
                        </div>
                    </a>
                    <a href="/coins/@worstVsXmr.Coin.Symbol.ToLower()" class="vs-xmr-link">
                        <div class="vs-xmr-body">
                            <span class="vs-xmr-label">Worst</span>
                            <div class="vs-xmr-value" id="vs-xmr-worst">
                                @if (!string.IsNullOrEmpty(worstVsXmr.Coin.ImageUrl))
                                {
                                    <img src="@worstVsXmr.Coin.ImageUrl" width="18" height="18" class="coin-icon" />
                                }
                                <span class="vs-xmr-symbol">@worstVsXmr.Coin.Symbol</span>
                                <span class="text-danger mono vs-xmr-pct">
                                    ▼ @Math.Abs(worstVsXmr.VsXmr).ToString("N2")%
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}

<div class="table-meta">
    <span>
        <span class="text-muted">Data updated:</span>
        <span id="last-updated-bar"
              class="cursor-default"
              title="@(Model.Coins.Any() ? Model.Coins.Max(c => c.UpdatedAt).ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "")">
            @(Model.Coins.Any() ? Model.Coins.Max(c => c.UpdatedAt).ToString("HH:mm:ss") + " UTC" : "pending...")
        </span>
    </span>
    <span>
        <span class="text-muted">Next update in:</span>
        <span id="countdown-bar">60</span>s
    </span>
</div>

@if (!Model.Coins.Any())
{
    <div class="empty-state">
        <p>No coin data yet.</p>
    </div>
}
else
{
    <div class="table-responsive"
         data-currency-code="@cur.Code"
         data-currency-symbol="@cur.Symbol"
         data-currency-before="@(cur.SymbolBefore ? "1" : "0")"
         data-currency-decimals="@cur.Decimals"
         data-currency-culture="@cur.Culture"
         data-rate-per-usd="@(rate.ToString(System.Globalization.CultureInfo.InvariantCulture))">
        <table class="table market-table">
            <thead>
                <tr>
                    <th class="col-rank sortable" data-sort="mcap"># <span class="sort-indicator">▼</span></th>
                    <th class="sortable" data-sort="name">Coin <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="price">Price (@cur.Code) <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="xmr-price">Price (XMR) <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="change-1h">1h % <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="change">24h % <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="change-7d">7d % <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="mcap">Market Cap <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="volume">24h Volume <span class="sort-indicator"></span></th>
                    <th class="text-end sortable" data-sort="supply">Supply <span class="sort-indicator"></span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coin in Model.Coins.OrderByDescending(c => MoneroSupplyDisplay.EffectiveMarketCapUsd(c)))
                {
                    var effectiveMcap = MoneroSupplyDisplay.EffectiveMarketCapUsd(coin);
                    var effectiveSupply = MoneroSupplyDisplay.EffectiveCirculatingSupply(coin);
                    var isNodeVerified = MoneroSupplyDisplay.IsNodeVerified(coin);

                    var priceInXmr = Model.Monero != null && Model.Monero.PriceUsd > 0
                        ? coin.PriceUsd / Model.Monero.PriceUsd : 0;

                    bool isXmr = coin.Symbol.ToUpper() == "XMR";

                    <tr class="@(isXmr ? "xmr-row" : "")"
                        data-symbol="@coin.Symbol"
                        data-name="@coin.Symbol.ToLower()"
                        data-price="@coin.PriceUsd"
                        data-xmr-price="@priceInXmr"
                        data-change1h="@coin.PriceChangePercent1h"
                        data-change="@coin.PriceChangePercent24h"
                        data-change7d="@coin.PriceChangePercent7d"
                        data-mcap="@effectiveMcap"
                        data-volume="@coin.TotalVolume"
                        data-supply="@effectiveSupply"
                        data-node-verified="@(isNodeVerified ? "true" : "false")">
                        <td class="rank-cell cell-rank"></td>
                        <td>
                            <div class="coin-name-cell">
                                @if (!string.IsNullOrEmpty(coin.ImageUrl))
                                {
                                    <a href="/coins/@coin.Symbol.ToLower()">
                                        <img src="@coin.ImageUrl" width="20" height="20" class="coin-icon" />
                                    </a>
                                }
                                <a href="/coins/@coin.Symbol.ToLower()" class="coin-symbol coin-link">@coin.Symbol</a>
                                <a href="/coins/@coin.Symbol.ToLower()" class="coin-name coin-name-link d-none d-lg-inline">@coin.Name</a>
                                @if (isXmr)
                                {
                                    <span class="xmr-badge">base</span>
                                }
                            </div>
                        </td>
                        <td class="text-end mono cell-price">@MoneyFormatter.FormatPrice(coin.PriceUsd, cur, rate)</td>
                        <td class="text-end mono xmr-val cell-xmr-price">
                            @if (isXmr)
                            {
                                <span>1 XMR</span>
                            }
                            else if (priceInXmr >= 1)
                            {
                                @($"{priceInXmr:N4} XMR")
                            }
                            else
                            {
                                @($"{priceInXmr:N8} XMR")
                            }
                        </td>
                        <td class="text-end mono cell-change-1h @(coin.PriceChangePercent1h >= 0 ? "text-success" : "text-danger")">
                            @(coin.PriceChangePercent1h >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent1h).ToString("N2")%
                        </td>
                        <td class="text-end mono cell-change @(coin.PriceChangePercent24h >= 0 ? "text-success" : "text-danger")">
                            @(coin.PriceChangePercent24h >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent24h).ToString("N2")%
                        </td>
                        <td class="text-end mono cell-change-7d @(coin.PriceChangePercent7d >= 0 ? "text-success" : "text-danger")">
                            @(coin.PriceChangePercent7d >= 0 ? "▲" : "▼") @Math.Abs(coin.PriceChangePercent7d).ToString("N2")%
                        </td>
                        <td class="text-end mono cell-mcap">
                            @MoneyFormatter.FormatLarge(effectiveMcap, cur, rate)
                        </td>
                        <td class="text-end mono cell-volume">
                            @MoneyFormatter.FormatLarge(coin.TotalVolume, cur, rate)
                        </td>
                        <td class="text-end mono cell-supply">
                            @FormatUnits(effectiveSupply)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}


<partial name="_SponsorList" />


@functions {
    static readonly System.Globalization.CultureInfo _en = System.Globalization.CultureInfo.GetCultureInfo("en-US");

    string FormatUnits(decimal value) => value switch
    {
        >= 1_000_000_000m => (value / 1_000_000_000m).ToString("N2", _en) + "B",
        >= 1_000_000m => (value / 1_000_000m).ToString("N2", _en) + "M",
        >= 1_000m => (value / 1_000m).ToString("N2", _en) + "K",
        _ => value.ToString("N0", _en)
    };
}

@section Scripts {
    <script>
        // ─── Currency context: read from the table-responsive wrapper ───────────
        // Server-rendered with the current cookie/query selection. The /api/Prices
        // endpoint will ALSO return its own currency block so we stay in sync if
        // the user changes currency in another tab.
        const _tableWrap = document.querySelector('.table-responsive[data-rate-per-usd]');
        let CURRENCY = _tableWrap ? {
            code:     _tableWrap.dataset.currencyCode,
            symbol:   _tableWrap.dataset.currencySymbol,
            before:   _tableWrap.dataset.currencyBefore === '1',
            decimals: parseInt(_tableWrap.dataset.currencyDecimals, 10) || 2,
            rate:     parseFloat(_tableWrap.dataset.ratePerUsd) || 1
        } : { code: 'USD', symbol: '$', before: true, decimals: 2, rate: 1 };

        function wrapMoney(numberPart) {
            return CURRENCY.before
                ? CURRENCY.symbol + numberPart
                : numberPart + ' ' + CURRENCY.symbol;
        }

        function formatLarge(vUsd) {
            const v = vUsd * CURRENCY.rate;
            let n;
            if (v >= 1e12) n = (v / 1e12).toFixed(2) + 'T';
            else if (v >= 1e9) n = (v / 1e9).toFixed(2) + 'B';
            else if (v >= 1e6) n = (v / 1e6).toFixed(2) + 'M';
            else if (v >= 1e3) n = (v / 1e3).toFixed(2) + 'K';
            else n = v.toFixed(2);
            return wrapMoney(n);
        }
        function formatUnits(v) {
            if (v >= 1e9) return (v / 1e9).toFixed(2) + 'B';
            if (v >= 1e6) return (v / 1e6).toFixed(2) + 'M';
            if (v >= 1e3) return (v / 1e3).toFixed(2) + 'K';
            return Math.round(v).toLocaleString();
        }
        function formatPrice(vUsd) {
            const v = vUsd * CURRENCY.rate;
            let n;
            if (CURRENCY.decimals === 0) {
                n = v >= 1
                    ? v.toLocaleString('en-US', { maximumFractionDigits: 0 })
                    : v.toFixed(2);
            } else if (v >= 1) {
                n = v.toLocaleString('en-US', {
                    minimumFractionDigits: CURRENCY.decimals,
                    maximumFractionDigits: CURRENCY.decimals
                });
            } else if (v >= 0.01) {
                n = v.toFixed(4);
            } else if (v >= 0.0001) {
                n = v.toFixed(6);
            } else {
                n = v.toFixed(8);
            }
            return wrapMoney(n);
        }
        function formatXmrPrice(priceUsd, xmrPriceUsd) {
            if (!xmrPriceUsd) return '—';
            const r = priceUsd / xmrPriceUsd;
            return r >= 1 ? r.toFixed(4) + ' XMR' : r.toFixed(8) + ' XMR';
        }
        function formatChangeCell(val) {
            const up = val >= 0;
            return {
                text: (up ? '▲ ' : '▼ ') + Math.abs(val).toFixed(2) + '%',
                cls: 'text-end mono ' + (up ? 'text-success' : 'text-danger')
            };
        }

        // --- Sort state ---
        let sortCol = 'mcap';
        let sortDir = 'desc';

        function applySort() {
            const tbody = document.querySelector('.market-table tbody');
            if (!tbody) return;

            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                if (sortCol === 'name') {
                    const aVal = a.dataset.name || '';
                    const bVal = b.dataset.name || '';
                    return sortDir === 'asc' ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
                }
                const dsKey = {
                    'mcap': 'mcap',
                    'price': 'price',
                    'xmr-price': 'xmrPrice',
                    'change': 'change',
                    'change-1h': 'change1h',
                    'change-7d': 'change7d',
                    'volume': 'volume',
                    'supply': 'supply'
                }[sortCol] || sortCol;
                const aVal = parseFloat(a.dataset[dsKey]) || 0;
                const bVal = parseFloat(b.dataset[dsKey]) || 0;
                return sortDir === 'asc' ? aVal - bVal : bVal - aVal;
            });

            rows.forEach((row, idx) => {
                const rankCell = row.querySelector('.cell-rank');
                if (rankCell) rankCell.textContent = idx + 1;
                tbody.appendChild(row);
            });

            document.querySelectorAll('.market-table thead th').forEach(th => {
                const indicator = th.querySelector('.sort-indicator');
                if (!indicator) return;
                indicator.textContent = th.dataset.sort === sortCol
                    ? (sortDir === 'asc' ? '▲' : '▼')
                    : '';
            });
        }

        document.querySelectorAll('.market-table thead th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (sortCol === col) {
                    sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                } else {
                    sortCol = col;
                    sortDir = col === 'name' ? 'asc' : 'desc';
                }
                applySort();
            });
        });

        applySort();

        async function refreshPrices() {
            try {
                const res = await fetch('/api/Prices');
                if (!res.ok) return;
                const payload = await res.json();
                // Backwards compat: payload may be either the new object form
                // ({ currency, coins }) or the old flat array form.
                const coins = Array.isArray(payload) ? payload : payload.coins;
                if (payload && payload.currency) {
                    CURRENCY = {
                        code:     payload.currency.code,
                        symbol:   payload.currency.symbol,
                        before:   payload.currency.before,
                        decimals: payload.currency.decimals,
                        rate:     payload.currency.ratePerUsd
                    };
                }
                if (!coins) return;
                const xmr = coins.find(c => c.symbol === 'XMR');
                if (!xmr) return;

                const xmrRow = document.querySelector('tr[data-symbol="XMR"]');
                const xmrSupply = xmrRow ? parseFloat(xmrRow.dataset.supply) || 0 : 0;
                const xmrEffectiveMcapUsd = xmrSupply * xmr.priceUsd;

                const xmrChangeHelper = (id, val) => {
                    const el = document.getElementById(id);
                    if (!el) return;
                    const up = val >= 0;
                    el.textContent = (up ? '▲ ' : '▼ ') + Math.abs(val).toFixed(2) + '%';
                    el.className = up ? 'text-success' : 'text-danger';
                };
                xmrChangeHelper('xmr-1h', xmr.priceChangePercent1h);
                xmrChangeHelper('xmr-24h', xmr.priceChangePercent24h);
                xmrChangeHelper('xmr-7d', xmr.priceChangePercent7d);
                xmrChangeHelper('xmr-30d', xmr.priceChangePercent30d);
                xmrChangeHelper('xmr-1y', xmr.priceChangePercent1y);

                const priceEl = document.getElementById('xmr-price');
                if (priceEl) priceEl.textContent = formatPrice(xmr.priceUsd);
                const mcapEl = document.getElementById('xmr-mcap');
                if (mcapEl) mcapEl.textContent = formatLarge(xmrEffectiveMcapUsd);
                const rankEl = document.getElementById('xmr-rank');
                if (rankEl) rankEl.textContent = 'Rank #' + xmr.marketCapRank;

                coins.forEach(coin => {
                    const row = document.querySelector('tr[data-symbol="' + coin.symbol + '"]');
                    if (!row) return;
                    const isXmr = coin.symbol === 'XMR';

                    const coinEffectiveSupply = parseFloat(row.dataset.supply) || 0;
                    const coinEffectiveMcapUsd = coinEffectiveSupply * coin.priceUsd;
                    const priceInXmr = xmr.priceUsd > 0 ? coin.priceUsd / xmr.priceUsd : 0;

                    row.dataset.price = coin.priceUsd;
                    row.dataset.xmrPrice = priceInXmr;
                    row.dataset.change1h = coin.priceChangePercent1h;
                    row.dataset.change = coin.priceChangePercent24h;
                    row.dataset.change7d = coin.priceChangePercent7d;
                    row.dataset.mcap = coinEffectiveMcapUsd;
                    row.dataset.volume = coin.totalVolume;

                    const priceCell = row.querySelector('.cell-price');
                    if (priceCell) priceCell.textContent = formatPrice(coin.priceUsd);

                    const change1hCell = row.querySelector('.cell-change-1h');
                    if (change1hCell) {
                        const f = formatChangeCell(coin.priceChangePercent1h);
                        change1hCell.textContent = f.text;
                        change1hCell.className = f.cls + ' cell-change-1h';
                    }

                    const xmrPriceCell = row.querySelector('.cell-xmr-price');
                    if (xmrPriceCell) xmrPriceCell.textContent = isXmr ? '1 XMR' : formatXmrPrice(coin.priceUsd, xmr.priceUsd);

                    const changeCell = row.querySelector('.cell-change');
                    if (changeCell) {
                        const f = formatChangeCell(coin.priceChangePercent24h);
                        changeCell.textContent = f.text;
                        changeCell.className = f.cls + ' cell-change';
                    }

                    const change7dCell = row.querySelector('.cell-change-7d');
                    if (change7dCell) {
                        const f = formatChangeCell(coin.priceChangePercent7d);
                        change7dCell.textContent = f.text;
                        change7dCell.className = f.cls + ' cell-change-7d';
                    }

                    const mcapCell = row.querySelector('.cell-mcap');
                    if (mcapCell) mcapCell.textContent = formatLarge(coinEffectiveMcapUsd);

                    const volumeCell = row.querySelector('.cell-volume');
                    if (volumeCell) volumeCell.textContent = formatLarge(coin.totalVolume);
                });

                // Recompute best/worst vs XMR (top stat bar) — currency-invariant.
                if (xmr && xmr.priceChangePercent7d !== undefined) {
                    const vsXmrList = coins
                        .filter(c => c.symbol !== 'XMR')
                        .map(c => ({
                            symbol: c.symbol,
                            name: c.name,
                            imageUrl: c.imageUrl,
                            vsXmr: ((1 + c.priceChangePercent7d / 100)
                                  / (1 + xmr.priceChangePercent7d / 100) - 1) * 100
                        }))
                        .filter(x => Number.isFinite(x.vsXmr));

                    if (vsXmrList.length) {
                        const best = vsXmrList.reduce((a, b) => b.vsXmr > a.vsXmr ? b : a);
                        const worst = vsXmrList.reduce((a, b) => b.vsXmr < a.vsXmr ? b : a);

                        const bestCard = document.getElementById('vs-xmr-best');
                        const worstCard = document.getElementById('vs-xmr-worst');
                        if (bestCard) {
                            bestCard.innerHTML =
                                (best.imageUrl ? `<img src="${best.imageUrl}" width="18" height="18" class="coin-icon" />` : '') +
                                `<span class="vs-xmr-symbol">${best.symbol}</span>` +
                                `<span class="text-success mono vs-xmr-pct">▲ ${best.vsXmr.toFixed(2)}%</span>`;
                            bestCard.parentElement.parentElement.href = '/coins/' + best.symbol.toLowerCase();
                        }
                        if (worstCard) {
                            worstCard.innerHTML =
                                (worst.imageUrl ? `<img src="${worst.imageUrl}" width="18" height="18" class="coin-icon" />` : '') +
                                `<span class="vs-xmr-symbol">${worst.symbol}</span>` +
                                `<span class="text-danger mono vs-xmr-pct">▼ ${Math.abs(worst.vsXmr).toFixed(2)}%</span>`;
                            worstCard.parentElement.parentElement.href = '/coins/' + worst.symbol.toLowerCase();
                        }
                    }
                }

                applySort();
            } catch (e) {
                console.error('Price refresh failed:', e);
            }
        }

        let seconds = 60;
        const countdownBar = document.getElementById('countdown-bar');
        const lastUpdatedBar = document.getElementById('last-updated-bar');
        setInterval(() => {
            seconds--;
            if (countdownBar) countdownBar.textContent = seconds;
            if (seconds <= 0) {
                seconds = 60;
                refreshPrices().then(() => {
                    const now = new Date();
                    const timeStr = now.toUTCString().split(' ')[4] + ' UTC';
                    if (lastUpdatedBar) {
                        lastUpdatedBar.textContent = timeStr;
                        lastUpdatedBar.title = now.toUTCString();
                    }
                });
            }
        }, 1000);
    </script>
}
