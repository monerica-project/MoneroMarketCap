@page
@model RegisterModel

<h2>Create Account</h2>

@if (Model.GeneratedUsername != null)
{
    <div style="border:1px solid green; padding:1rem; margin:1rem 0;">
        <strong>Save these credentials — they won't be shown again!</strong><br />
        Username: <code>@Model.GeneratedUsername</code><br />
        Password: <code>@Model.GeneratedPassword</code>
    </div>
    <a href="/Login">Go to Login</a>
}
else
{
    <form method="post">
        @Html.AntiForgeryToken()
        <p>@Model.CaptchaQuestion</p>
        <input type="number" name="CaptchaAnswer" required />
        @if (!string.IsNullOrEmpty(Model.CaptchaError))
        {
            <p style="color:red;">@Model.CaptchaError</p>
        }
        <button type="submit">Generate My Account</button>
    </form>
}