@page
@model MoneroMarketCap.Pages.Portfolios.TransactionsModel
@using MoneroMarketCap.Data.Models
@{
    ViewData["Title"] = "Transaction History";
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    string Mask(string v) => Model.PrivacyMode ? "••••" : v;
}

<meta name="format-detection" content="telephone=no" />

@if (Model.PortfolioCoin == null)
{
    <p>Not found.</p>
    return;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h2 class="mb-1">
            <a href="/coins/@Model.PortfolioCoin.Coin.Symbol.ToLower()" style="color:inherit;text-decoration:none">
                @Model.PortfolioCoin.Coin.Symbol
            </a> — Transaction History
        </h2>
        <p class="mb-0" style="color:var(--xmr-text-muted)">
            Portfolio: <strong>@Model.PortfolioCoin.Portfolio.Name</strong>
        </p>
    </div>
    <div>
        <partial name="_PrivacyToggle" />
    </div>
</div>

<div class="mb-4">
    <a asp-page="/Portfolios/Detail" asp-route-id="@Model.PortfolioCoin.PortfolioId"
       class="btn btn-secondary btn-sm">← Back to Portfolio</a>
</div>

<!-- Transaction list -->
@if (!Model.Transactions.Any())
{
    <p class="text-muted">No transactions yet.</p>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table market-table" style="font-size:0.82rem">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Price (USD)</th>
                    <th class="text-end">Total (USD)</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Transactions)
                {
                    <tr>
                        <td>@t.TransactedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <span class="@(t.Type == TransactionType.Buy ? "text-success" : "text-danger")">
                                @t.Type
                            </span>
                        </td>
                        <td class="text-end mono">@Mask(t.Amount.ToString("N12", usd))</td>
                        <td class="text-end mono">@Mask($"${t.PriceUsdAtTime.ToString("N8", usd)}")</td>
                        <td class="text-end mono">@Mask($"${t.TotalUsd.ToString("N2", usd)}")</td>
                        <td>@t.Notes</td>
                        <td class="text-end">
                            <form method="post"
                                  asp-page-handler="Delete"
                                  asp-route-portfolioCoinId="@Model.PortfolioCoin.Id"
                                  asp-route-transactionId="@t.Id"
                                  onsubmit="return confirm('Delete this transaction?')"
                                  style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">✕</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Add transaction -->
<div class="card" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
    <div class="card-header">Add Transaction</div>
    <div class="card-body">
        <form method="post"
              asp-page-handler="Add"
              asp-route-portfolioCoinId="@Model.PortfolioCoin.Id"
              class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <select asp-for="TransactionType" class="form-select">
                    <option value="Buy">Buy</option>
                    <option value="Sell">Sell</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Amount</label>
                <input asp-for="Amount" type="number" step="any" min="0" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Price at Time (USD)</label>
                <input asp-for="PriceUsdAtTime" type="number" step="any" min="0" class="form-control" id="price-input" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Notes</label>
                <input asp-for="Notes" class="form-control" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Add</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Pre-fill price with current coin price on load
        document.getElementById('price-input').value = @Model.CoinCurrentPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
    </script>
}