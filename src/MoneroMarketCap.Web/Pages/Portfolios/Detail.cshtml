@page "{id:int}"
@model MoneroMarketCap.Pages.Portfolios.DetailModel
@using MoneroMarketCap.Data.Models
@{
    ViewData["Title"] = Model.Portfolio?.Name ?? "Portfolio";
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    decimal xmrVal(decimal v) => Model.XmrPrice > 0 ? v / Model.XmrPrice : 0;
    var totalAlloc = Model.Allocations.Sum(a => a.ValueUsd);
    string Mask(string v) => Model.PrivacyMode ? "••••" : v;
}

<meta name="format-detection" content="telephone=no" />

@if (Model.Portfolio == null)
{
    <p>Portfolio not found.</p>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="mb-0">@Model.Portfolio.Name</h2>
    <div class="text-end">
        <div class="fs-5">Total Value: <strong>@Mask($"${Model.Portfolio.TotalValueUsd.ToString("N2", usd)}")</strong></div>
        @if (Model.XmrPrice > 0)
        {
            <div style="color:var(--xmr-text-muted);font-size:0.85rem;white-space:nowrap">
                @Mask($"{xmrVal(Model.Portfolio.TotalValueUsd).ToString("N4", usd)} XMR")
            </div>
        }
        <div class="mt-2">
            <partial name="_PrivacyToggle" />
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ImportMessage))
{
    <div class="alert @(Model.ImportSuccess ? "alert-success" : "alert-warning") mb-3">
        @Model.ImportMessage
    </div>
}

<div class="d-flex gap-2 mb-4 flex-wrap">
    <a asp-page="/Portfolios/Index" class="btn btn-secondary btn-sm">← Back</a>
    <button type="button"
            class="btn btn-outline-warning btn-sm"
            onclick="const p=document.getElementById('import-panel');p.style.display=p.style.display==='none'?'':'none';">
        ⬆ Import from Monero GUI
    </button>
    <form method="post"
          asp-page-handler="DeletePortfolio"
          asp-route-id="@Model.Portfolio.Id"
          onsubmit="return confirm('Delete portfolio \'@Model.Portfolio.Name\'? This cannot be undone.')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger btn-sm">🗑 Delete Portfolio</button>
    </form>
</div>

<div id="import-panel" class="card mb-4" style="display:none;background:var(--xmr-surface);border-color:var(--xmr-border)">
    <div class="card-header">Import XMR Transactions from Monero GUI CSV</div>
    <div class="card-body">
        <p style="color:var(--xmr-text-muted);font-size:0.85rem">
            Export your transactions from the Monero GUI wallet (<em>History → Export as CSV</em>) and upload the file here.
            Transactions will be added to the <strong>XMR</strong> coin in this portfolio.
            <strong>Incoming</strong> becomes Buy, <strong>outgoing</strong> becomes Sell. Historical USD price per day is
            looked up automatically. Duplicates (by txid) are skipped.
        </p>
        <form method="post"
              asp-page-handler="ImportMonero"
              asp-route-id="@Model.Portfolio.Id"
              enctype="multipart/form-data"
              class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-8">
                <label class="form-label">Monero GUI CSV file</label>
                <input type="file" name="ImportFile" accept=".csv,text/csv" class="form-control" required />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">Import</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Allocations.Any() && totalAlloc > 0 || (!Model.PrivacyMode && Model.PnlSeries.Any()))
{
    <div class="row mb-4">
        @if (Model.Allocations.Any() && totalAlloc > 0)
        {
            <div class="col-lg-5 mb-3">
                <div class="card h-100" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Allocation</h5>
                        <div style="position:relative;max-width:320px;margin:0 auto">
                            <canvas id="portfolioAllocationChart" style="cursor:pointer"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.PrivacyMode && Model.PnlSeries.Any())
        {
            <div class="col-lg-7 mb-3">
                <div class="card h-100" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0">P&amp;L Over Time</h5>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-primary active" id="pnl-toggle-usd">USD</button>
                                <button type="button" class="btn btn-outline-primary" id="pnl-toggle-xmr">XMR</button>
                            </div>
                        </div>
                        <div style="position:relative;height:280px">
                            <canvas id="pnlChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (!Model.Portfolio.PortfolioCoins.Any())
{
    <p class="text-muted">No coins yet. Add a transaction below.</p>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table market-table" style="font-size:0.82rem">
            <thead>
                <tr>
                    <th>Coin</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Value (USD)</th>
                    @if (Model.XmrPrice > 0)
                    {
                        <th class="text-end">Value (XMR)</th>
                    }
                    <th class="text-end">Basis</th>
                    <th class="text-end">P&amp;L</th>
                    @if (Model.XmrPrice > 0)
                    {
                        <th class="text-end">P&amp;L (XMR)</th>
                    }
                    <th class="text-end">%</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pc in Model.Portfolio.PortfolioCoins.OrderBy(p => p.Coin.Symbol))
                {
                    var isXmrRow = pc.Coin.Symbol.ToUpper() == "XMR";
                    var pct = Model.Portfolio.TotalValueUsd > 0
                        ? (double)(pc.TotalValueUsd / Model.Portfolio.TotalValueUsd) * 100.0
                        : 0.0;
                    <tr>
                        <td>
                            <div class="coin-name-cell">
                                @if (!string.IsNullOrEmpty(pc.Coin.ImageUrl))
                                {
                                    <a href="/coins/@pc.Coin.Symbol.ToLower()">
                                        <img src="@pc.Coin.ImageUrl" width="18" height="18" style="border-radius:50%;flex-shrink:0" />
                                    </a>
                                }
                                <a href="/coins/@pc.Coin.Symbol.ToLower()" class="coin-symbol" style="color:inherit;text-decoration:none">@pc.Coin.Symbol</a>
                                <a href="/coins/@pc.Coin.Symbol.ToLower()" class="coin-name d-none d-lg-inline" style="color:var(--xmr-text-muted);text-decoration:none">@pc.Coin.Name</a>
                            </div>
                        </td>
                        <td class="text-end mono">@Mask(pc.TotalAmount.ToString("N8", usd))</td>
                        <td class="text-end mono">$@pc.Coin.PriceUsd.ToString("N2", usd)</td>
                        <td class="text-end mono">@Mask($"${pc.TotalValueUsd.ToString("N2", usd)}")</td>
                        @if (Model.XmrPrice > 0)
                        {
                            <td class="text-end mono xmr-val">
                                @if (isXmrRow)
                                {
                                    <span style="color:var(--xmr-text-muted)">—</span>
                                }
                                else
                                {
                                    @Mask($"{xmrVal(pc.TotalValueUsd).ToString("N4", usd)} XMR")
                                }
                            </td>
                        }
                        <td class="text-end mono">@Mask($"${pc.TotalCostBasis.ToString("N2", usd)}")</td>
                        <td class="text-end mono @(pc.UnrealizedPnl >= 0 ? "text-success" : "text-danger")">
                            @Mask($"${pc.UnrealizedPnl.ToString("N2", usd)}")
                        </td>
                        @if (Model.XmrPrice > 0)
                        {
                            <td class="text-end mono xmr-val @(isXmrRow ? "" : (pc.UnrealizedPnl >= 0 ? "text-success" : "text-danger"))">
                                @if (isXmrRow)
                                {
                                    <span style="color:var(--xmr-text-muted)">—</span>
                                }
                                else
                                {
                                    @Mask($"{xmrVal(pc.UnrealizedPnl).ToString("N4", usd)} XMR")
                                }
                            </td>
                        }
                        <td class="text-end mono">@pct.ToString("N2", usd)%</td>
                        <td class="text-end">
                            <a asp-page="/Portfolios/Transactions"
                               asp-route-portfolioCoinId="@pc.Id"
                               class="btn btn-outline-secondary btn-sm">History</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @{
                    var totalPnl = Model.Portfolio.PortfolioCoins.Sum(p => p.UnrealizedPnl);
                    var totalBasis = Model.Portfolio.PortfolioCoins.Sum(p => p.TotalCostBasis);
                }
                <tr style="border-top:2px solid var(--xmr-border);font-weight:600">
                    <td colspan="3">Total</td>
                    <td class="text-end mono">@Mask($"${Model.Portfolio.TotalValueUsd.ToString("N2", usd)}")</td>
                    @if (Model.XmrPrice > 0)
                    {
                        <td class="text-end mono xmr-val">@Mask($"{xmrVal(Model.Portfolio.TotalValueUsd).ToString("N4", usd)} XMR")</td>
                    }
                    <td class="text-end mono">@Mask($"${totalBasis.ToString("N2", usd)}")</td>
                    <td class="text-end mono @(totalPnl >= 0 ? "text-success" : "text-danger")">
                        @Mask($"${totalPnl.ToString("N2", usd)}")
                    </td>
                    @if (Model.XmrPrice > 0)
                    {
                        <td class="text-end mono @(totalPnl >= 0 ? "text-success" : "text-danger") xmr-val">
                            @Mask($"{xmrVal(totalPnl).ToString("N4", usd)} XMR")
                        </td>
                    }
                    <td class="text-end mono">100.00%</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<div class="card mt-2" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
    <div class="card-header">Add Transaction</div>
    <div class="card-body">
        <form method="post" asp-page-handler="AddTransaction" asp-route-id="@Model.Portfolio.Id" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-2">
                <label class="form-label">Coin</label>
                <select asp-for="CoinId" asp-items="Model.CoinOptions" class="form-select" id="coin-select"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Date (UTC)</label>
                <input asp-for="TransactedAt" type="datetime-local" class="form-control"
                       value="@Model.TransactedAt.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
            <div class="col-md-1">
                <label class="form-label">Type</label>
                <select asp-for="TransactionType" class="form-select">
                    <option value="Buy">Buy</option>
                    <option value="Sell">Sell</option>
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label">Amount</label>
                <input asp-for="Amount" type="number" step="any" min="0" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Price (USD)</label>
                <input asp-for="PriceUsdAtTime" type="number" step="any" min="0" class="form-control" id="price-input" />
            </div>
            <div class="col-md-2">
                <label class="form-label">External ID</label>
                <input asp-for="ExternalTransactionId" class="form-control" placeholder="e.g. transaction ID" />
            </div>
            <div class="col-md-1">
                <label class="form-label">Notes</label>
                <input asp-for="Notes" class="form-control" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Add</button>
            </div>
        </form>
    </div>
</div>


<partial name="_SponsorList" />

@section Scripts {
    <script src="~/js/chart.umd.min.js"></script>
    <script>
        const privacyMode = @(Model.PrivacyMode ? "true" : "false");

        // ─── Allocation pie ─────────────────────────────────────
        (function() {
        const allocLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Allocations.Select(a => a.Symbol)));
        const allocValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Allocations.Select(a => (double)a.ValueUsd)));
        if (allocLabels.length === 0) return;

        const palette = [
        '#4a90e2', '#50c878', '#e74c3c', '#9b59b6', '#f1c40f',
        '#1abc9c', '#e67e22', '#34495e', '#ff69b4', '#2ecc71',
        '#8e44ad', '#3498db', '#d35400', '#16a085', '#c0392b'
        ];
        const xmrOrange = '#ff6600';
        let idx = 0;
        const colors = allocLabels.map(l => l === 'XMR' ? xmrOrange : palette[idx++ % palette.length]);
        const total = allocValues.reduce((s, v) => s + v, 0);

        const canvas = document.getElementById('portfolioAllocationChart');
        if (!canvas) return;
        new Chart(canvas.getContext('2d'), {
        type: 'pie',
        data: {
        labels: allocLabels,
        datasets: [{ data: allocValues, backgroundColor: colors, borderColor: 'rgba(0,0,0,0.3)', borderWidth: 1 }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        onClick: function(evt, els) {
        if (els && els.length > 0) window.location.href = '/coins/' + allocLabels[els[0].index].toLowerCase();
        },
        onHover: function(evt, els) {
        evt.native.target.style.cursor = (els && els.length > 0) ? 'pointer' : 'default';
        },
        plugins: {
        legend: {
        position: 'bottom',
        labels: { color: getComputedStyle(document.body).color },
        onClick: function(evt, item) { window.location.href = '/coins/' + item.text.toLowerCase(); }
        },
        tooltip: {
        callbacks: {
        label: function(c) {
        const v = c.parsed;
        const pct = total > 0 ? (v / total * 100).toFixed(2) : '0.00';
        if (privacyMode) {
        return c.label + ': ' + pct + '%';
        }
        return c.label + ': $' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' (' + pct + '%)';
        }
        }
        }
        }
        }
        });
        })();

        // ─── P&L over time (hidden in privacy mode) ─────────────
        (function() {
        if (privacyMode) return;

        const pnlSeries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.PnlSeries,
                    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
                    ));
        if (!pnlSeries || pnlSeries.length === 0) return;

        const canvas = document.getElementById('pnlChart');
        if (!canvas) return;

        let mode = 'usd';
        const labels = pnlSeries.map(p => new Date(p.timestampMs).toISOString().slice(0, 10));

        function dataFor(m) { return pnlSeries.map(p => m === 'usd' ? p.pnlUsd : p.pnlXmr); }

        const chart = new Chart(canvas.getContext('2d'), {
        type: 'line',
        data: {
        labels: labels,
        datasets: [{
        label: 'P&L (USD)',
        data: dataFor('usd'),
        borderColor: '#ff6600',
        backgroundColor: 'rgba(255, 102, 0, 0.1)',
        borderWidth: 2,
        fill: true,
        tension: 0.2,
        pointRadius: 0,
        pointHoverRadius: 4
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        scales: {
        x: {
        ticks: { color: getComputedStyle(document.body).color, maxRotation: 0, autoSkip: true, maxTicksLimit: 8 },
        grid: { color: 'rgba(128,128,128,0.15)' }
        },
        y: {
        ticks: {
        color: getComputedStyle(document.body).color,
        callback: function(val) {
        if (mode === 'usd') return '$' + val.toLocaleString('en-US', { maximumFractionDigits: 0 });
        return val.toFixed(4) + ' XMR';
        }
        },
        grid: { color: 'rgba(128,128,128,0.15)' }
        }
        },
        plugins: {
        legend: { display: false },
        tooltip: {
        callbacks: {
        label: function(c) {
        const v = c.parsed.y;
        if (mode === 'usd') return 'P&L: $' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return 'P&L: ' + v.toFixed(4) + ' XMR';
        }
        }
        }
        }
        }
        });

        function setMode(newMode) {
        mode = newMode;
        chart.data.datasets[0].label = 'P&L (' + (mode === 'usd' ? 'USD' : 'XMR') + ')';
        chart.data.datasets[0].data = dataFor(mode);
        chart.update();
        document.getElementById('pnl-toggle-usd').classList.toggle('active', mode === 'usd');
        document.getElementById('pnl-toggle-xmr').classList.toggle('active', mode === 'xmr');
        }
        document.getElementById('pnl-toggle-usd').addEventListener('click', () => setMode('usd'));
        document.getElementById('pnl-toggle-xmr').addEventListener('click', () => setMode('xmr'));
        })();

        // ─── Existing: price auto-fill on coin select ──────────
        const prices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CoinPrices));
        const coinSelect = document.getElementById('coin-select');
        const priceInput = document.getElementById('price-input');

        function updatePrice() {
        const id = parseInt(coinSelect.value);
        if (prices[id] !== undefined) {
        priceInput.value = prices[id];
        }
        }

        coinSelect.addEventListener('change', updatePrice);
        updatePrice();
    </script>
}
