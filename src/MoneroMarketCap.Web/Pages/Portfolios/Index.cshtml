@page
@model MoneroMarketCap.Pages.Portfolios.IndexModel
@{
    ViewData["Title"] = "My Portfolios";
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
}

<meta name="format-detection" content="telephone=no" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Portfolios</h2>
    <div class="text-end">
        <div class="fs-5">Total Net Value: <strong>$@Model.TotalNetValue.ToString("N2", usd)</strong></div>
        @if (Model.XmrPrice > 0)
        {
            <div style="color:var(--xmr-text-muted);font-size:0.85rem;white-space:nowrap">
                @((Model.TotalNetValue / Model.XmrPrice).ToString("N4", usd)) XMR
            </div>
        }
    </div>
</div>

@if (!Model.Portfolios.Any())
{
    <p class="text-muted">No portfolios yet. Create one below.</p>
}
else
{
    <div class="row mb-4">
        @foreach (var p in Model.Portfolios)
        {
            <div class="col-md-4 mb-3">
                <div class="card" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
                    <div class="card-body">
                        <h5 class="card-title">@p.Name</h5>
                        <p class="card-text mb-1">
                            Value: <strong>$@p.TotalValueUsd.ToString("N2", usd)</strong>
                        </p>
                        @if (Model.XmrPrice > 0)
                        {
                            <p class="card-text mb-1" style="color:var(--xmr-text-muted);font-size:0.82rem;white-space:nowrap">
                                @((p.TotalValueUsd / Model.XmrPrice).ToString("N4", usd)) XMR
                            </p>
                        }
                        <p class="card-text mb-2" style="font-size:0.85rem">
                            Coins: @p.PortfolioCoins.Count
                        </p>
                        <a asp-page="/Portfolios/Detail" asp-route-id="@p.Id" class="btn btn-primary btn-sm">View</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<h5>Create New Portfolio</h5>
<form method="post" asp-page-handler="Create" class="row g-2">
    <div class="col-auto">
        <input asp-for="PortfolioName" class="form-control" placeholder="Portfolio name" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-success">Create</button>
    </div>
</form>