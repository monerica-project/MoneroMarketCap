@page
@model MoneroMarketCap.Pages.Portfolios.IndexModel
@{
    ViewData["Title"] = "My Portfolios";
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var totalAlloc = Model.Allocations.Sum(a => a.ValueUsd);
}

<meta name="format-detection" content="telephone=no" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Portfolios</h2>
    <div class="text-end">
        <div class="fs-5">Total Net Value: <strong>$@Model.TotalNetValue.ToString("N2", usd)</strong></div>
        @if (Model.XmrPrice > 0)
        {
            <div style="color:var(--xmr-text-muted);font-size:0.85rem;white-space:nowrap">
                @((Model.TotalNetValue / Model.XmrPrice).ToString("N4", usd)) XMR
            </div>
        }
    </div>
</div>

@if (!Model.Portfolios.Any())
{
    <p class="text-muted">No portfolios yet. Create one below.</p>
}
else
{
    @if (Model.Allocations.Any() && totalAlloc > 0)
    {
        <div class="card mb-4" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
            <div class="card-body">
                <h5 class="card-title mb-3">Allocation by Coin</h5>
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <div style="position:relative;max-width:340px;margin:0 auto">
                            <canvas id="allocationChart" style="cursor:pointer"></canvas>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <table class="table table-sm mb-0" style="color:inherit">
                            <thead>
                                <tr>
                                    <th>Coin</th>
                                    <th class="text-end">Value (USD)</th>
                                    <th class="text-end">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.Allocations)
                                {
                                    var pct = (double)(a.ValueUsd / totalAlloc) * 100.0;
                                    <tr>
                                        <td><a href="/coins/@a.Symbol.ToLower()"><strong>@a.Symbol</strong></a></td>
                                        <td class="text-end">$@a.ValueUsd.ToString("N2", usd)</td>
                                        <td class="text-end">@pct.ToString("N2", usd)%</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Total</th>
                                    <th class="text-end">$@totalAlloc.ToString("N2", usd)</th>
                                    <th class="text-end">100.00%</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row mb-4">
        @foreach (var p in Model.Portfolios)
        {
            <div class="col-md-4 mb-3">
                <div class="card" style="background:var(--xmr-surface);border-color:var(--xmr-border)">
                    <div class="card-body">
                        <h5 class="card-title">@p.Name</h5>
                        <p class="card-text mb-1">
                            Value: <strong>$@p.TotalValueUsd.ToString("N2", usd)</strong>
                        </p>
                        @if (Model.XmrPrice > 0)
                        {
                            <p class="card-text mb-1" style="color:var(--xmr-text-muted);font-size:0.82rem;white-space:nowrap">
                                @((p.TotalValueUsd / Model.XmrPrice).ToString("N4", usd)) XMR
                            </p>
                        }
                        <p class="card-text mb-2" style="font-size:0.85rem">
                            Coins: @p.PortfolioCoins.Count
                        </p>
                        <a asp-page="/Portfolios/Detail" asp-route-id="@p.Id" class="btn btn-primary btn-sm">View</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<h5>Create New Portfolio</h5>
<form method="post" asp-page-handler="Create" class="row g-2">
    <div class="col-auto">
        <input asp-for="PortfolioName" class="form-control" placeholder="Portfolio name" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-success">Create</button>
    </div>
</form>

<partial name="_SponsorList" />

@if (Model.Allocations.Any() && totalAlloc > 0)
{
    <script src="~/js/chart.umd.min.js"></script>
    <script>
        (function() {
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Allocations.Select(a => a.Symbol)));
        const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Allocations.Select(a => (double)a.ValueUsd)));
        const palette = [
        '#4a90e2', '#50c878', '#e74c3c', '#9b59b6', '#f1c40f',
        '#1abc9c', '#e67e22', '#34495e', '#ff69b4', '#2ecc71',
        '#8e44ad', '#3498db', '#d35400', '#16a085', '#c0392b'
        ];
        const xmrOrange = '#ff6600';
        let paletteIdx = 0;
        const colors = labels.map(label => {
        if (label === 'XMR') return xmrOrange;
        return palette[paletteIdx++ % palette.length];
        });
        const total = values.reduce((s, v) => s + v, 0);

        const canvas = document.getElementById('allocationChart');
        const ctx = canvas.getContext('2d');
        const chart = new Chart(ctx, {
        type: 'pie',
        data: {
        labels: labels,
        datasets: [{
        data: values,
        backgroundColor: colors,
        borderColor: 'rgba(0,0,0,0.3)',
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        onClick: function(evt, elements) {
        if (elements && elements.length > 0) {
        const idx = elements[0].index;
        const sym = labels[idx];
        if (sym) window.location.href = '/coins/' + sym.toLowerCase();
        }
        },
        onHover: function(evt, elements) {
        evt.native.target.style.cursor = (elements && elements.length > 0) ? 'pointer' : 'default';
        },
        plugins: {
        legend: {
        position: 'bottom',
        labels: { color: getComputedStyle(document.body).color },
        onClick: function(evt, legendItem) {
        const sym = legendItem.text;
        if (sym) window.location.href = '/coins/' + sym.toLowerCase();
        }
        },
        tooltip: {
        callbacks: {
        label: function(ctx) {
        const v = ctx.parsed;
        const pct = total > 0 ? (v / total * 100).toFixed(2) : '0.00';
        return ctx.label + ': $' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' (' + pct + '%)';
        }
        }
        }
        }
        }
        });
        })();
    </script>
}
