@page
@using MoneroMarketCap.Web.Helpers
@model MoneroMarketCap.Pages.Portfolios.IndexModel
@{
    ViewData["Title"] = "My Portfolios";
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var cur = Model.Currency;
    var rate = Model.RatePerUsd;
    var totalAlloc = Model.Allocations.Sum(a => a.ValueUsd);

    string totalPnlPctText = "";
    decimal totalPnlPctVal = 0m;
    if (Model.TotalCostBasis > 0)
    {
        totalPnlPctVal = (Model.TotalPnl / Model.TotalCostBasis) * 100m;
        var sign = totalPnlPctVal >= 0 ? "+" : "";
        totalPnlPctText = sign + totalPnlPctVal.ToString("N2", usd) + "%";
    }

    string Mask(string v) => Model.PrivacyMode ? "••••" : v;
    string MaskedAttr() => Model.PrivacyMode ? "true" : "false";
    string FormatAmount(decimal v, string sym) =>
        v >= 1m
            ? $"{v.ToString("N4", usd)} {sym}"
            : $"{v.ToString("N8", usd)} {sym}";
}

<meta name="format-detection" content="telephone=no" />

<style>
    @@keyframes valueFlashUp {
        0%   { background-color: rgba(76, 175, 80, 0.35); }
        100% { background-color: transparent; }
    }
    @@keyframes valueFlashDown {
        0%   { background-color: rgba(244, 67, 54, 0.35); }
        100% { background-color: transparent; }
    }
    .value-up   { animation: valueFlashUp   1.2s ease-out; border-radius: 3px; padding: 0 2px; }
    .value-down { animation: valueFlashDown 1.2s ease-out; border-radius: 3px; padding: 0 2px; }
</style>

<div class="portfolio-header d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="mb-0">My Portfolios</h2>
    <div class="text-end portfolio-summary">
        <div class="portfolio-total">
            Total Net Value:
            <strong data-anim="totalNetValue" data-value="@Model.TotalNetValue" data-masked="@MaskedAttr()">@Mask(MoneyFormatter.FormatValue(Model.TotalNetValue, cur, rate))</strong>
        </div>
        @if (Model.XmrPrice > 0)
        {
            <div class="portfolio-xmr-equiv">
                <span data-anim="totalNetValueXmr" data-value="@(Model.TotalNetValue / Model.XmrPrice)" data-masked="@MaskedAttr()">@Mask($"{(Model.TotalNetValue / Model.XmrPrice).ToString("N4", usd)} XMR")</span>
            </div>
        }
        <div class="portfolio-pnl-line mt-1">
            Total P&amp;L:
            <strong data-anim="totalPnl" data-value="@Model.TotalPnl" data-masked="@MaskedAttr()" class="@(Model.TotalPnl >= 0 ? "text-success" : "text-danger")">@Mask(MoneyFormatter.FormatSigned(Model.TotalPnl, cur, rate))</strong>
            @if (!string.IsNullOrEmpty(totalPnlPctText))
            {
                <span data-anim="totalPnlPct" data-value="@totalPnlPctVal" data-masked="false" class="@(Model.TotalPnl >= 0 ? "text-success" : "text-danger")">(@totalPnlPctText)</span>
            }
            @if (Model.XmrPrice > 0)
            {
                <span class="portfolio-pnl-xmr @(Model.TotalPnl >= 0 ? "text-success" : "text-danger")" data-anim="totalPnlXmr" data-value="@(Model.TotalPnl / Model.XmrPrice)" data-masked="@MaskedAttr()">
                    (@Mask($"{(Model.TotalPnl / Model.XmrPrice).ToString("N4", usd)} XMR"))
                </span>
            }
        </div>
        <div class="mt-2">
            <partial name="_PrivacyToggle" />
        </div>
        <div class="portfolio-refresh-meta mt-1 small text-muted">
            Next check: <span id="refreshCountdown">60</span>s
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.FlashMessage))
{
    <div class="alert @(Model.FlashSuccess ? "alert-success" : "alert-danger") mb-3" role="alert">
        @Model.FlashMessage
    </div>
}

@if (!Model.Portfolios.Any())
{
    <p class="text-muted">No portfolios yet. Create one below.</p>
}
else
{
    @if (Model.Allocations.Any() && totalAlloc > 0)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Allocation by Coin</h5>
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <div class="allocation-chart-wrap">
                            <canvas id="allocationChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="table-responsive">
                            <table class="table table-sm allocation-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Coin</th>
                                        <th class="text-end">Price (@cur.Code)</th>
                                        <th class="text-end">Total Held</th>
                                        <th class="text-end">Value (@cur.Code)</th>
                                        <th class="text-end">%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in Model.Allocations)
                                    {
                                        var pct = (a.ValueUsd / totalAlloc) * 100m;
                                        <tr>
                                            <td><a href="/coins/@a.Symbol.ToLower()"><strong>@a.Symbol</strong></a></td>
                                            <td class="text-end mono"><span data-coin="@a.Symbol" data-field="price" data-value="@a.PriceUsd" data-masked="false">@MoneyFormatter.FormatPrice(a.PriceUsd, cur, rate)</span></td>
                                            <td class="text-end mono"><span data-coin="@a.Symbol" data-field="amount" data-sym="@a.Symbol" data-value="@a.TotalAmount" data-masked="@MaskedAttr()">@Mask(FormatAmount(a.TotalAmount, a.Symbol))</span></td>
                                            <td class="text-end mono"><span data-coin="@a.Symbol" data-field="value" data-value="@a.ValueUsd" data-masked="@MaskedAttr()">@Mask(MoneyFormatter.FormatValue(a.ValueUsd, cur, rate))</span></td>
                                            <td class="text-end mono"><span data-coin="@a.Symbol" data-field="pct" data-value="@pct" data-masked="false">@pct.ToString("N2", usd)%</span></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th colspan="3">Total</th>
                                        <th class="text-end mono"><span data-anim="allocTotal" data-value="@totalAlloc" data-masked="@MaskedAttr()">@Mask(MoneyFormatter.FormatValue(totalAlloc, cur, rate))</span></th>
                                        <th class="text-end mono">100.00%</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row mb-4">
        @foreach (var p in Model.Portfolios)
        {
            var pPnl = p.PortfolioCoins.Sum(pc => pc.UnrealizedPnl);
            var pBasis = p.PortfolioCoins.Sum(pc => pc.TotalCostBasis);
            string pPctText = "";
            decimal pPctVal = 0m;
            if (pBasis > 0)
            {
                pPctVal = (pPnl / pBasis) * 100m;
                var pSign = pPctVal >= 0 ? "+" : "";
                pPctText = pSign + pPctVal.ToString("N2", usd) + "%";
            }
            string pPnlClass = pPnl >= 0 ? "text-success" : "text-danger";

            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@p.Name</h5>
                        <p class="card-text mb-1">
                            Value: <strong data-portfolio="@p.Id" data-field="value" data-value="@p.TotalValueUsd" data-masked="@MaskedAttr()">@Mask(MoneyFormatter.FormatValue(p.TotalValueUsd, cur, rate))</strong>
                        </p>
                        @if (Model.XmrPrice > 0)
                        {
                            <p class="card-text mb-1 portfolio-card-xmr">
                                <span data-portfolio="@p.Id" data-field="valueXmr" data-value="@(p.TotalValueUsd / Model.XmrPrice)" data-masked="@MaskedAttr()">@Mask($"{(p.TotalValueUsd / Model.XmrPrice).ToString("N4", usd)} XMR")</span>
                            </p>
                        }
                        <p class="card-text mb-1">
                            P&amp;L:
                            <strong data-portfolio="@p.Id" data-field="pnl" data-value="@pPnl" data-masked="@MaskedAttr()" class="@pPnlClass">@Mask(MoneyFormatter.FormatSigned(pPnl, cur, rate))</strong>
                            @if (!string.IsNullOrEmpty(pPctText))
                            {
                                <span data-portfolio="@p.Id" data-field="pnlPct" data-value="@pPctVal" data-masked="false" class="@pPnlClass">(@pPctText)</span>
                            }
                        </p>
                        <p class="card-text mb-2 portfolio-card-meta">
                            Coins: @p.PortfolioCoins.Count
                        </p>
                        <a asp-page="/Portfolios/Detail" asp-route-id="@p.Id" class="btn btn-primary btn-sm">View</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<h5>Create New Portfolio</h5>
<form method="post" asp-page-handler="Create" class="row g-2">
    <div class="col-auto">
        <input asp-for="PortfolioName" class="form-control" placeholder="Portfolio name" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-success">Create</button>
    </div>
</form>

<partial name="_SponsorList" />

<script>
    // Currency context for client-side formatting on refresh. Mirrors what
    // /api/Prices uses elsewhere — kept inline because portfolio refresh uses
    // its own ?handler=Snapshot endpoint.
    window.__MMC_CURRENCY__ = {
        code:     @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cur.Code)),
        symbol:   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cur.Symbol)),
        before:   @(cur.SymbolBefore ? "true" : "false"),
        decimals: @cur.Decimals,
        rate:     @rate.ToString(System.Globalization.CultureInfo.InvariantCulture)
    };
</script>

@if (Model.Allocations.Any() && totalAlloc > 0)
{
    <script src="~/js/chart.umd.min.js"></script>
    <script>
        (function() {
            const privacyMode = @(Model.PrivacyMode ? "true" : "false");
            const C = window.__MMC_CURRENCY__;
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Allocations.Select(a => a.Symbol)));
            // Convert allocation values to display currency for the chart.
            const valuesUsd = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Allocations.Select(a => (double)a.ValueUsd)));
            const values = valuesUsd.map(v => v * C.rate);
            const palette = [
                '#4a90e2', '#50c878', '#e74c3c', '#9b59b6', '#f1c40f',
                '#1abc9c', '#e67e22', '#34495e', '#ff69b4', '#2ecc71',
                '#8e44ad', '#3498db', '#d35400', '#16a085', '#c0392b'
            ];
            const xmrOrange = '#ff6600';
            let paletteIdx = 0;
            const colors = labels.map(label => {
                if (label === 'XMR') return xmrOrange;
                return palette[paletteIdx++ % palette.length];
            });

            const canvas = document.getElementById('allocationChart');
            const ctx = canvas.getContext('2d');
            const chart = new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: colors,
                        borderColor: 'rgba(0,0,0,0.3)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    onClick: function(evt, elements) {
                        if (elements && elements.length > 0) {
                            const idx = elements[0].index;
                            const sym = labels[idx];
                            if (sym) window.location.href = '/coins/' + sym.toLowerCase();
                        }
                    },
                    onHover: function(evt, elements) {
                        evt.native.target.style.cursor = (elements && elements.length > 0) ? 'pointer' : 'default';
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: getComputedStyle(document.body).color },
                            onClick: function(evt, legendItem) {
                                const sym = legendItem.text;
                                if (sym) window.location.href = '/coins/' + sym.toLowerCase();
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(ctx) {
                                    const v = ctx.parsed;
                                    const datasetTotal = ctx.dataset.data.reduce((s, x) => s + x, 0);
                                    const pct = datasetTotal > 0 ? (v / datasetTotal * 100).toFixed(2) : '0.00';
                                    if (privacyMode) {
                                        return ctx.label + ': ' + pct + '%';
                                    }
                                    const numFmt = v.toLocaleString('en-US', { minimumFractionDigits: C.decimals, maximumFractionDigits: C.decimals });
                                    const money = C.before ? C.symbol + numFmt : numFmt + ' ' + C.symbol;
                                    return ctx.label + ': ' + money + ' (' + pct + '%)';
                                }
                            }
                        }
                    }
                }
            });
            window.__allocationChart = chart;
        })();
    </script>
}

<script>
    window.__PORTFOLIO_VERSION__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DataVersion));
</script>
<script>
    (function () {
        const CHECK_SECONDS = 60;
        const EPSILON = 1e-9;
        let lastVersion = window.__PORTFOLIO_VERSION__ || '';
        // Currency context — updated on each snapshot in case the user changed it in another tab.
        let C = window.__MMC_CURRENCY__;
        let remaining = CHECK_SECONDS;
        let checking = false;
        const countdownEl = document.getElementById('refreshCountdown');

        const numFmt = (n, min, max) => n.toLocaleString('en-US', { minimumFractionDigits: min, maximumFractionDigits: max });

        function wrapMoney(numberPart) {
            return C.before ? C.symbol + numberPart : numberPart + ' ' + C.symbol;
        }

        function formatCurrency(vUsd) {
            const v = vUsd * C.rate;
            const sign = v < 0 ? '-' : '';
            const abs = Math.abs(v);
            return sign + wrapMoney(numFmt(abs, C.decimals, C.decimals));
        }
        function formatXmr(v)          { return numFmt(v, 4, 4) + ' XMR'; }
        function formatPctSigned(v)    { return (v >= 0 ? '+' : '') + numFmt(v, 2, 2) + '%'; }
        function formatPctPlain(v)     { return numFmt(v, 2, 2) + '%'; }
        function formatPrice(vUsd) {
            const v = vUsd * C.rate;
            if (C.decimals === 0) {
                return v >= 1
                    ? wrapMoney(numFmt(v, 0, 0))
                    : wrapMoney(v.toFixed(2));
            }
            if (v >= 1)      return wrapMoney(numFmt(v, C.decimals, C.decimals));
            if (v >= 0.01)   return wrapMoney(numFmt(v, 4, 4));
            if (v >= 0.0001) return wrapMoney(numFmt(v, 6, 6));
            return wrapMoney(numFmt(v, 8, 8));
        }
        function formatAmount(v, sym) {
            if (v >= 1) return numFmt(v, 4, 4) + ' ' + sym;
            return numFmt(v, 8, 8) + ' ' + sym;
        }

        // P&L keeps sub-$1 precision (tiered on magnitude) and re-attaches the sign,
        // mirroring MoneyFormatter.FormatSigned. Plain prices/values are NOT used here:
        // a small gain/loss must stay visible (e.g. +$0.0234) instead of rounding to $0.02.
        function formatPnlUsd(vUsd) {
            const v = vUsd * C.rate;
            const sign = v < 0 ? '-' : '';
            const a = Math.abs(v);
            let n;
            if (C.decimals === 0) {
                n = a >= 1 ? numFmt(a, 0, 0) : a.toFixed(2);
            } else if (a >= 1) {
                n = numFmt(a, C.decimals, C.decimals);
            } else if (a >= 0.01) {
                n = numFmt(a, 4, 4);
            } else if (a >= 0.0001) {
                n = numFmt(a, 6, 6);
            } else {
                n = numFmt(a, 8, 8);
            }
            return sign + wrapMoney(n);
        }

        function animateNumber(el, fromVal, toVal, formatFn) {
            const masked = el.dataset.masked === 'true';
            el.setAttribute('data-value', toVal);
            if (masked) return;

            const duration = 700;
            const start = performance.now();
            function frame(now) {
                const t = Math.min(1, (now - start) / duration);
                const eased = 1 - Math.pow(1 - t, 3);
                const cur = fromVal + (toVal - fromVal) * eased;
                el.textContent = formatFn(cur);
                if (t < 1) requestAnimationFrame(frame);
                else el.textContent = formatFn(toVal);
            }
            requestAnimationFrame(frame);

            // Flash
            el.classList.remove('value-up', 'value-down');
            void el.offsetWidth;
            el.classList.add(toVal > fromVal ? 'value-up' : 'value-down');
        }

        function updateValue(el, newVal, formatFn) {
            if (!el) return;
            const oldVal = parseFloat(el.getAttribute('data-value'));
            if (isNaN(oldVal)) {
                el.setAttribute('data-value', newVal);
                if (el.dataset.masked !== 'true') el.textContent = formatFn(newVal);
                return;
            }
            if (Math.abs(oldVal - newVal) < EPSILON) return;
            animateNumber(el, oldVal, newVal, formatFn);
        }

        function setPnlClass(el, isPositive) {
            if (!el) return;
            el.classList.remove('text-success', 'text-danger');
            el.classList.add(isPositive ? 'text-success' : 'text-danger');
        }

        function applySnapshot(data) {
            // Reload on structural change (coin set or portfolio set changed).
            const allocEls = document.querySelectorAll('[data-coin][data-field="value"]');
            const existingCoins = new Set([...allocEls].map(e => e.getAttribute('data-coin')));
            const incomingCoins = new Set((data.allocations || []).map(a => a.symbol));
            if (existingCoins.size !== incomingCoins.size ||
                [...existingCoins].some(c => !incomingCoins.has(c))) {
                window.location.reload();
                return;
            }

            const portfolioEls = document.querySelectorAll('[data-portfolio][data-field="value"]');
            const existingPids = new Set([...portfolioEls].map(e => e.getAttribute('data-portfolio')));
            const incomingPids = new Set((data.portfolios || []).map(p => String(p.id)));
            if (existingPids.size !== incomingPids.size ||
                [...existingPids].some(p => !incomingPids.has(p))) {
                window.location.reload();
                return;
            }

            // Pick up currency from snapshot — handles user changing currency
            // in another tab without a full reload of this one.
            if (data.currency && data.currency.code !== C.code) {
                C = {
                    code: data.currency.code,
                    symbol: data.currency.symbol,
                    before: data.currency.before,
                    decimals: data.currency.decimals,
                    rate: data.currency.ratePerUsd
                };
                // Easiest: reload so the column headers and other server-rendered bits also update.
                window.location.reload();
                return;
            }
            if (data.currency) {
                C.rate = data.currency.ratePerUsd; // refresh the rate even if currency unchanged
            }

            updateValue(document.querySelector('[data-anim="totalNetValue"]'),
                        data.totalNetValue, formatCurrency);

            if (data.xmrPrice > 0) {
                updateValue(document.querySelector('[data-anim="totalNetValueXmr"]'),
                            data.totalNetValue / data.xmrPrice, formatXmr);
            }

            const pnlEl = document.querySelector('[data-anim="totalPnl"]');
            updateValue(pnlEl, data.totalPnl, formatPnlUsd);
            setPnlClass(pnlEl, data.totalPnl >= 0);

            if (data.totalCostBasis > 0) {
                const pct = (data.totalPnl / data.totalCostBasis) * 100;
                const pctEl = document.querySelector('[data-anim="totalPnlPct"]');
                updateValue(pctEl, pct, v => '(' + formatPctSigned(v) + ')');
                setPnlClass(pctEl, data.totalPnl >= 0);
            }

            if (data.xmrPrice > 0) {
                const xmrEl = document.querySelector('[data-anim="totalPnlXmr"]');
                updateValue(xmrEl, data.totalPnl / data.xmrPrice, v => '(' + formatXmr(v) + ')');
                setPnlClass(xmrEl, data.totalPnl >= 0);
            }

            // Allocations
            let totalAlloc = 0;
            (data.allocations || []).forEach(a => totalAlloc += a.valueUsd);

            (data.allocations || []).forEach(a => {
                const base = `[data-coin="${a.symbol}"]`;
                updateValue(document.querySelector(`${base}[data-field="price"]`),
                            a.priceUsd, formatPrice);
                updateValue(document.querySelector(`${base}[data-field="amount"]`),
                            a.totalAmount, v => formatAmount(v, a.symbol));
                updateValue(document.querySelector(`${base}[data-field="value"]`),
                            a.valueUsd, formatCurrency);
                const pct = totalAlloc > 0 ? (a.valueUsd / totalAlloc) * 100 : 0;
                updateValue(document.querySelector(`${base}[data-field="pct"]`),
                            pct, formatPctPlain);
            });
            updateValue(document.querySelector('[data-anim="allocTotal"]'),
                        totalAlloc, formatCurrency);

            // Portfolios
            (data.portfolios || []).forEach(p => {
                const base = `[data-portfolio="${p.id}"]`;
                updateValue(document.querySelector(`${base}[data-field="value"]`),
                            p.totalValueUsd, formatCurrency);
                if (data.xmrPrice > 0) {
                    updateValue(document.querySelector(`${base}[data-field="valueXmr"]`),
                                p.totalValueUsd / data.xmrPrice, formatXmr);
                }
                const pPnlEl = document.querySelector(`${base}[data-field="pnl"]`);
                updateValue(pPnlEl, p.pnl, formatPnlUsd);
                setPnlClass(pPnlEl, p.pnl >= 0);

                if (p.costBasis > 0) {
                    const pct = (p.pnl / p.costBasis) * 100;
                    const pPctEl = document.querySelector(`${base}[data-field="pnlPct"]`);
                    updateValue(pPctEl, pct, v => '(' + formatPctSigned(v) + ')');
                    setPnlClass(pPctEl, p.pnl >= 0);
                }
            });

            // Allocation chart — values in display currency.
            const chart = window.__allocationChart;
            if (chart) {
                const newSeries = (data.allocations || []).map(a => {
                    const idx = chart.data.labels.indexOf(a.symbol);
                    return { idx, val: a.valueUsd * C.rate };
                });
                const oldData = chart.data.datasets[0].data;
                let changed = false;
                const updatedData = oldData.slice();
                newSeries.forEach(({ idx, val }) => {
                    if (idx < 0) return;
                    if (Math.abs(oldData[idx] - val) > EPSILON) {
                        updatedData[idx] = val;
                        changed = true;
                    }
                });
                if (changed) {
                    chart.data.datasets[0].data = updatedData;
                    chart.update();
                }
            }
        }

        function isUserBusy() {
            const a = document.activeElement;
            if (!a) return false;
            const tag = a.tagName;
            return tag === 'INPUT' || tag === 'TEXTAREA' || a.isContentEditable;
        }

        async function check() {
            if (checking) return;
            checking = true;
            try {
                const resp = await fetch('?handler=Snapshot', {
                    headers: { 'Accept': 'application/json' },
                    credentials: 'same-origin',
                    cache: 'no-store'
                });
                if (!resp.ok) return;
                const data = await resp.json();
                if (!data) return;

                if (data.version && data.version === lastVersion) return;
                if (isUserBusy()) return;

                applySnapshot(data);
                lastVersion = data.version || lastVersion;
            } catch (e) {
                // network blip
            } finally {
                checking = false;
            }
        }

        function tick() {
            if (document.hidden) return;
            remaining--;
            if (countdownEl) countdownEl.textContent = remaining;
            if (remaining <= 0) {
                remaining = CHECK_SECONDS;
                check();
            }
        }

        setInterval(tick, 1000);
    })();
</script>